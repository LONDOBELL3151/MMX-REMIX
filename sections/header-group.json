s Now Available!🎊","text_alignment":"center","color_scheme":"background-2","link":"shopify:\/\/products\/maxfoot-mf-30-electric-assist-adult-tricycle-750w-front-suspension-neptune-blue"}}},"block_order":["96dc94ae-1330-4b4a-9831-046bff2901aa"],"disabled":true,"custom_css":[".h5 {font-size: 15px; color: #ffc60b;}"],"settings":{}},"400ee457-679a-4fa0-99a0-707a68f55891":{"type":"custom-liquid","name":"菜单醒目提示","settings":{"custom_liquid":"<style>\n  @keyframes pulse {\n  0% {\n      -webkit-transform: scale(1);\n      -ms-transform: scale(1);\n      transform: scale(1)\n  }\n\n  50% {\n      -webkit-transform: scale(1.1);\n      -ms-transform: scale(1.1);\n      transform: scale(1.1)\n  }\n\n  100% {\n      -webkit-transform: scale(1);\n      -ms-transform: scale(1);\n      transform: scale(1)\n  }\n}\n  .add_first,.add_fourth {\n    position: relative;\n  }\n\/* PC端字体 *\/ li.add_first:before,.add_fourth:before {\n    content: 'HOT';\n    position: absolute;\n    background: #ffc426;\n    border-radius: 8px;\n    padding: 1px 6px;\n    font-size: 12px;\n    line-height: 20px;\n    color: #000;\n    font-weight: 600;\n    border: initial;\n    top: 0;\n    right: 0;\nvisibility: visible;\nanimation-duration: 1500ms;\nanimation-iteration-count: infinite;\nanimation-name: pulse;\n  }\n  .add_fourth:before {\n    content: 'SALES';\n  }\n  .add_ {\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n  }\n  .add_title_hot {\n    background: #ffc426;\n    border-radius: 8px;\n    padding: 1px 6px;\n    font-size: 12px;\n    line-height: 20px;\n    color: #000;\n    font-weight: 600;\n    border: initial;\n   visibility: visible;\nanimation-duration: 1500ms;\nanimation-iteration-count: infinite;\nanimation-name: pulse;\n  } \n<\/style>\n<script>\n\n    document.querySelector('.header__inline-menu .list-menu li:nth-child(1)').classList.add('add_first');\n   document.querySelector('.header__inline-menu .list-menu li:nth-child(2)').classList.add('add_fourth');\n\n\/* 移动端字体 *\/ \n   let titleHot_a = document.createElement('span')\n      titleHot_a.innerText = \"HOT\"\n      titleHot_a.className = 'add_title_hot'\n    let titleHot_b = document.createElement('span')\n    titleHot_b.innerText = \"SALES\"\n    titleHot_b.className = 'add_title_hot'\n   document.querySelector('.menu-drawer__navigation .menu-drawer__menu li:nth-child(1)').classList.add('add_');\n   document.querySelector('.menu-drawer__navigation .menu-drawer__menu li:nth-child(1)').appendChild(titleHot_a);\n   document.querySelector('.menu-drawer__navigation .menu-drawer__menu li:nth-child(2)').classList.add('add_');\n   document.querySelector('.menu-drawer__navigation .menu-drawer__menu li:nth-child(2)').appendChild(titleHot_b);\n<\/script>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}}},"order":["custom_liquid_hyjYRz","9298d48e-f724-46c1-a737-72daebdd0c2c","announcement-bar","header","announcement-bar-2","400ee457-679a-4fa0-99a0-707a68f55891"]}