{"name":"t:sections.header.name","type":"header","sections":{"custom_liquid_hyjYRz":{"type":"custom-liquid","disabled":true,"settings":{"custom_liquid":"<style>\n        #all {\n            background-color: #6f727a;\n            block-size: auto;\n            display: flex;\n            justify-content: space-between;\n\n\n        }\n\n        #text {\n            color: #ffcd00;\n            font-size: 20px;\n            text-align: left;\n            padding-left: 50px;\n        }\n\n        #remainTime {\n            font-size: 20px;\n            text-align: right;\n            padding-right: 50px;\n        }\n\n        #remainTime span1 {\n            color: #ffcd00;\n            font-weight: bold;\n            margin-right: 10px;\n        }\n\n        #remainTime span2 {\n            color: #ffffff;\n        }\n\n        a {\n            text-decoration: none;\n            color: #ffcd00;\n        }\n\n        @media (max-width: 500px) {\n            #all {\n                display: block;\n            }\n\n            #text {\n                font-size: 16px;\n                text-align: center;\n                padding-left: 0px;\n            }\n\n            #remainTime {\n                text-align: center;\n                padding-right: 0px;\n            }\n        }\n\n        @media (max-width: 920px) {\n            #all {\n                display: block;\n            }\n\n            #text {\n                text-align: center;\n                padding-left: 0px;\n            }\n\n            #remainTime {\n                text-align: center;\n                padding-right: 0px;\n            }\n        }\n    <\/style>\n\n    <div id=\"all\">\n        <div id=\"text\">\n            <span><a href=\"https:\/\/maxfoot.bike\/pages\/prime-day\">👉🏻 Prime Month Sale Ends Soon 👈🏻<\/a>\n            <\/span>\n        <\/div>\n\n        <div id=\"remainTime\">\n            <span2>Ends After:<\/span2>\n            <span1 id=\"one\" class=\"time_days\"><\/span1>\n            <span2>d<\/span2>\n            &nbsp;&nbsp;\n            <span1 id=\"two\" class=\"time_hours\"><\/span1>\n            <span2>h<\/span2>&nbsp;&nbsp;\n            <span1 id=\"three\" class=\"time_minutes\"><\/span1>\n            <span2>m<\/span2>&nbsp;&nbsp;\n            <span1 id=\"four\" class=\"time_seconds\"><\/span1>\n            <span2>s<\/span2>\n        <\/div>\n    <\/div>\n\n\n    <script>\n\n        const getTimeZone = function(date) {\n            let opts = {\n                timeZone: 'America\/Los_Angeles',\n                year: 'numeric',\n                month: '2-digit',\n                day: '2-digit',\n                hour: '2-digit',\n                minute: '2-digit',\n                second: '2-digit',\n                hourCycle: 'h23'\n            }\n            return Intl.DateTimeFormat('en-US', opts).format(date)\n        }\n        \/\/ 目标时间\n        const ritime = '2024\/09\/30 11:59:59'\n        \/\/ 区时\n        \/\/ const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone\n\n        \/\/ 初始化\n        document.querySelector('.time_days').innerText = 0\n        document.querySelector('.time_hours').innerText = 0\n        document.querySelector('.time_minutes').innerText = 0\n        document.querySelector('.time_seconds').innerText = 0\n\n        \/\/ 循环获取最新时间\n        setInterval(() => {\n            \/\/ counter = as(ritime)\n            document.querySelector('.time_days').innerText = as(ritime).split('-')[0]\n            document.querySelector('.time_hours').innerText = as(ritime).split('-')[1]\n            document.querySelector('.time_minutes').innerText = as(ritime).split('-')[2]\n            document.querySelector('.time_seconds').innerText = as(ritime).split('-')[3]\n        }, 1000)\n\n        function as(dar) {\n            const leftTime = new Date(getTimeZone(new Date(dar))).getTime() - new Date(getTimeZone(new Date())).getTime()\n            const days = parseInt(leftTime \/ 1000 \/ 60 \/ 60 \/ 24 , 10); \/\/计算剩余的天数 \n            const hours = parseInt(leftTime \/ 1000 \/ 60 \/ 60 % 24 , 10); \/\/计算剩余的小时 \n            const minutes = parseInt(leftTime \/ 1000 \/ 60 % 60, 10);\/\/计算剩余的分钟 \n            const seconds = parseInt(leftTime \/ 1000 % 60, 10);\/\/计算剩余的秒数\n            if (leftTime <= 0) {\n                return '0'\n            }\n            return `${days}-${hours}-${minutes}-${seconds}`\n        }\n    <\/script>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"9298d48e-f724-46c1-a737-72daebdd0c2c":{"type":"custom-liquid","disabled":true,"custom_css":[],"settings":{"custom_liquid":"<style>\n  \/* 倒计时栏容器 *\/\n  .countdown-bar-compact {\n    display: flex; \/* 使用 Flexbox 布局 *\/\n    justify-content: space-between; \/* 左右两端对齐 *\/\n    align-items: center; \/* 垂直居中 *\/\n    background-color: #FEC338; \/* 背景颜色，可根据品牌调整 *\/\n    color: #121212; \/* 文字颜色 *\/\n    padding: 10px 15px; \/* 内边距 *\/\n    font-family: Arial, sans-serif; \/* 字体 *\/\n    font-size: 16px; \/* 整体字体大小 *\/\n    line-height: 1.2; \/* 行高 *\/\n    box-sizing: border-box; \/* 边框和内边距包含在元素总宽度和高度内 *\/\n  }\n\n  \/* 号召文案 *\/\n  .countdown-bar-compact__cta {\n    font-weight: bold; \/* 加粗 *\/\n    margin-right: 15px; \/* 与倒计时之间的间距 *\/\n    white-space: nowrap; \/* 防止文案换行 *\/\n    overflow: hidden; \/* 超出部分隐藏 *\/\n    text-overflow: ellipsis; \/* 超出部分显示省略号 *\/\n    flex-shrink: 1; \/* 允许收缩 *\/\n    color: inherit;\n  }\n\n  \/* 倒计时部分 *\/\n  .countdown-bar-compact__timer {\n    display: flex; \/* 使用 Flexbox 布局 *\/\n    align-items: center; \/* 垂直居中 *\/\n    gap: 8px; \/* 倒计时单位之间的间距 *\/\n    white-space: nowrap; \/* 防止倒计时换行 *\/\n    flex-shrink: 0; \/* 不允许收缩 *\/\n  }\n\n  \/* 倒计时数字 *\/\n  .countdown-bar-compact__timer-value {\n    font-size: 24px; \/* 数字大小 *\/\n    font-weight: bold; \/* 加粗 *\/\n    background-color: rgba(0, 0, 0, 0.2); \/* 数字背景 *\/\n    padding: 2px 6px; \/* 数字内边距 *\/\n    border-radius: 3px; \/* 轻微圆角 *\/\n  }\n\n  \/* 倒计时标签（天、时等） *\/\n  .countdown-bar-compact__timer-label {\n    font-size: 14px; \/* 标签大小 *\/\n    margin-left: -4px; \/* 微调与数字的距离 *\/\n    text-transform: uppercase; \/* 转换为大写 *\/\n  }\n\n  \/* 冒号分隔符 *\/\n  .countdown-bar-compact__timer-separator {\n    font-size: 18px; \/* 冒号大小 *\/\n    font-weight: bold;\n  }\n\n  \/* 活动状态文本（即将开始\/已结束） *\/\n  .countdown-bar-compact__status-text {\n    font-size: 18px;\n    font-weight: bold;\n  }\n\n  \/* 响应式设计 *\/\n  \/* 当屏幕宽度小于或等于 750px 时，文案在上，倒计时在下 *\/\n  @media (max-width: 750px) {\n    .countdown-bar-compact {\n      flex-direction: column; \/* 垂直排列 *\/\n      justify-content: center; \/* 垂直居中对齐，确保内容在中间 *\/\n      align-items: center; \/* 水平居中 *\/\n      padding: 10px 15px; \/* 增加垂直内边距 *\/\n      font-size: 15px; \/* 减小整体字体 *\/\n    }\n\n    .countdown-bar-compact__cta {\n      margin-right: 0; \/* 移除右侧间距 *\/\n      margin-bottom: 5px; \/* 在文案下方添加间距 *\/\n      text-align: center; \/* 文本居中 *\/\n      white-space: normal; \/* 允许文案换行 *\/\n      max-width: 100%; \/* 确保占据全宽 *\/\n      overflow: visible; \/* 允许显示完整文本 *\/\n      text-overflow: clip; \/* 移除省略号 *\/\n    }\n\n    .countdown-bar-compact__timer {\n      gap: 7px; \/* 减小间距 *\/\n      justify-content: center; \/* 倒计时单位居中 *\/\n    }\n\n    .countdown-bar-compact__timer-value {\n      font-size: 20px; \/* 减小数字大小 *\/\n      padding: 2px 5px;\n    }\n\n    .countdown-bar-compact__timer-label {\n      font-size: 10.5px; \/* 减小标签大小 *\/\n      margin-left: -3px;\n    }\n\n    .countdown-bar-compact__timer-separator {\n      font-size: 17px;\n    }\n    .countdown-bar-compact__status-text {\n        font-size: 17px;\n     }\n  }\n\n  \/* 针对小于或等于 600px 的屏幕 (保持之前针对手机的优化) *\/\n  @media (max-width: 600px) {\n    .countdown-bar-compact {\n      font-size: 14px; \/* 减小整体字体 *\/\n      padding: 8px 10px; \/* 减小内边距 *\/\n    }\n\n    .countdown-bar-compact__cta {\n      margin-bottom: 4px; \/* 进一步减小底部间距 *\/\n    }\n\n    .countdown-bar-compact__timer {\n      gap: 6px; \/* 减小间距 *\/\n    }\n\n    .countdown-bar-compact__timer-value {\n      font-size: 20px; \/* 减小数字大小 *\/\n      padding: 1px 5px;\n    }\n\n    .countdown-bar-compact__timer-label {\n      font-size: 10px; \/* 减小标签大小 *\/\n      margin-left: -3px;\n    }\n\n    .countdown-bar-compact__timer-separator {\n      font-size: 16px;\n    }\n    .countdown-bar-compact__status-text {\n        font-size: 16px;\n     }\n  }\n<\/style>\n\n<div class=\"countdown-bar-compact\">\n  <a class=\"countdown-bar-compact__cta\" id=\"countdownCtaText\" href=\"https:\/\/maxfoot.bike\/pages\/sale\">\n      Don't miss out, enjoy your Black Friday!\n  <\/a>\n  <div class=\"countdown-bar-compact__timer\" id=\"countdownTimerCompact\">\n    <span class=\"countdown-bar-compact__timer-value\" id=\"daysCompact\">00<\/span>\n    <span class=\"countdown-bar-compact__timer-label\">day<\/span>\n    <span class=\"countdown-bar-compact__timer-separator\">:<\/span>\n    <span class=\"countdown-bar-compact__timer-value\" id=\"hoursCompact\">00<\/span>\n    <span class=\"countdown-bar-compact__timer-label\">hour<\/span>\n    <span class=\"countdown-bar-compact__timer-separator\">:<\/span>\n    <span class=\"countdown-bar-compact__timer-value\" id=\"minutesCompact\">00<\/span>\n    <span class=\"countdown-bar-compact__timer-label\">min<\/span>\n    <span class=\"countdown-bar-compact__timer-separator\">:<\/span>\n    <span class=\"countdown-bar-compact__timer-value\" id=\"secondsCompact\">00<\/span>\n    <span class=\"countdown-bar-compact__timer-label\">sec<\/span>\n  <\/div>\n<\/div>\n\n<script>\n  \/\/ 设置你的倒计时开始日期和结束日期\n  \/\/ 格式：YYYY-MM-DDTHH:MM:SS\n  const startDate = new Date(\"2025-10-10T16:00:00\").getTime(); \/\/ 活动开始时间\n  const endDate = new Date(\"2025-12-01T16:00:00\").getTime(); \/\/ 活动结束时间\n\n  const ctaTextElement = document.getElementById(\"countdownCtaText\");\n  const timerElement = document.getElementById(\"countdownTimerCompact\");\n\n  const countdownFunctionCompact = setInterval(function() {\n    const now = new Date().getTime();\n    let distance;\n    let ctaMessage;\n    let showTimer = true;\n\n    if (now < startDate) {\n      \/\/ 活动尚未开始\n      distance = startDate - now;\n      ctaMessage = \"Maxfoot Prime Month sale is about to begin! Time left until:\";\n      showTimer = true; \/\/ 仍然显示倒计时到开始时间\n    } else if (now >= startDate && now <= endDate) {\n      \/\/ 活动进行中\n      distance = endDate - now;\n      ctaMessage = \"Don't miss out, enjoy your Black Friday!\";\n      showTimer = true;\n    } else {\n      \/\/ 活动已结束\n      distance = -1; \/\/ 设置为负值以便清除倒计时\n      ctaMessage = \"Maxfoot Prime Month sale is end!\";\n      showTimer = false;\n    }\n\n    ctaTextElement.innerHTML = ctaMessage;\n\n    if (showTimer && distance >= 0) {\n      \/\/ 显示倒计时\n      timerElement.style.display = 'flex'; \/\/ 确保计时器显示\n      const days = Math.floor(distance \/ (1000 * 60 * 60 * 24));\n      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\n      const minutes = Math.floor((distance % (1000 * 60 * 60)) \/ (1000 * 60));\n      const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\n\n      document.getElementById(\"daysCompact\").innerHTML = String(days).padStart(2, '0');\n      document.getElementById(\"hoursCompact\").innerHTML = String(hours).padStart(2, '0');\n      document.getElementById(\"minutesCompact\").innerHTML = String(minutes).padStart(2, '0');\n      document.getElementById(\"secondsCompact\").innerHTML = String(seconds).padStart(2, '0');\n    } else {\n      \/\/ 不显示倒计时，或者显示结束文本\n      timerElement.style.display = 'flex'; \/\/ 确保显示容器\n      timerElement.innerHTML = `<span class=\"countdown-bar-compact__status-text\">${(now < startDate) ? \"即将开始！\" : \"Thanks for your supports.\"}<\/span>`;\n      if (distance < 0) {\n        clearInterval(countdownFunctionCompact); \/\/ 清除倒计时\n      }\n    }\n  }, 1000);\n<\/script>","color_scheme":"background-1","padding_top":0,"padding_bottom":0}},"announcement-bar":{"type":"announcement-bar","blocks":{"96dc94ae-1330-4b4a-9831-0