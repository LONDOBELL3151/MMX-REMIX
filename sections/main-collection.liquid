{%- liquid
  assign s = section.settings
  assign promo_blocks = section.blocks | where: 'type', 'promo'
-%}

{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}

<section class="main-collection" id="MainCollection" {{ section.shopify_attributes }}>
  <div class="container collection-grid">
    <div class="main-collection__sidebar">
      {%- comment -%}
        Facets UI inlined here. {% section %} cannot be nested inside a
        section, so the original {% section 'facets' %} would error.
        For merchant-configurable filter groups, the standalone
        sections/facets.liquid is still available to mount from
        templates/collection.json as a top-level section.
      {%- endcomment -%}
      <aside class="facets" id="Facets">
        <form id="FacetFiltersForm" class="facets__form" action="{{ collection.url }}" method="get">
          <div class="facets__clear">
            <a href="{{ collection.url }}">Clear all</a>
          </div>

          <details class="facets__group" open>
            <summary class="facets__title">Tags</summary>
            <ul class="facets__list">
              {%- for tag in collection.all_tags limit: 50 -%}
                <li>
                  <label>
                    <input type="checkbox" name="filter.p.tag" value="{{ tag | handleize }}" {% if current_tags contains tag %}checked{% endif %}>
                    <span>{{ tag }}</span>
                  </label>
                </li>
              {%- endfor -%}
            </ul>
          </details>

          <details class="facets__group">
            <summary class="facets__title">Price</summary>
            <div class="facets__price">
              <input type="number" name="filter.v.price.gte" placeholder="Min $" value="{{ min_price | default: '' }}">
              <span>—</span>
              <input type="number" name="filter.v.price.lte" placeholder="Max $" value="{{ max_price | default: '' }}">
              <button type="submit" class="btn btn--sm">Apply</button>
            </div>
          </details>
        </form>
        <div class="facets__mobile-actions">
          <button type="button" class="btn btn--primary btn--block" data-mobile-filters-close>Apply filters</button>
        </div>
      </aside>
    </div>

    <div class="main-collection__main">
      <div class="collection-toolbar">
        <button type="button" class="collection-toolbar__mobile-trigger" data-mobile-filters-open>
          {% render 'icon', icon: 'menu', size: 18 %}
          Filters
          {%- if current_tags.size > 0 -%}
            <span class="collection-toolbar__count">{{ current_tags.size }}</span>
          {%- endif -%}
        </button>

        <div class="collection-toolbar__count">
          <strong>{{ collection.products_count }}</strong> products
        </div>

        <div class="collection-toolbar__sort">
          <label for="SortBy">{{ 'products.facets.sort_by' | t: default: 'Sort by' }}:</label>
          <select name="sort_by" id="SortBy" data-sort-by>
            <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>{{ 'products.facets.featured' | t: default: 'Featured' }}</option>
            <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>{{ 'products.facets.best_selling' | t: default: 'Best selling' }}</option>
            <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>{{ 'products.facets.az' | t: default: 'A-Z' }}</option>
            <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>{{ 'products.facets.za' | t: default: 'Z-A' }}</option>
            <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>{{ 'products.facets.price_asc' | t: default: 'Price: Low to High' }}</option>
            <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>{{ 'products.facets.price_desc' | t: default: 'Price: High to Low' }}</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>{{ 'products.facets.date_desc' | t: default: 'Newest' }}</option>
          </select>
        </div>
      </div>

      {%- if collection.products.size == 0 -%}
        <div class="main-collection__empty">
          <h3>No products match those filters.</h3>
          <a href="{{ collection.url }}" class="btn btn--outline">Clear filters</a>
        </div>
      {%- else -%}
        {%- paginate collection.products by s.products_per_page -%}
          <div class="products products--grid products--3">
            {%- comment -%} Render position=0 promo blocks BEFORE the first product {%- endcomment -%}
            {%- for block in promo_blocks -%}
              {%- if block.settings.position == 0 -%}
                {% render 'promo-card', block: block %}
              {%- endif -%}
            {%- endfor -%}

            {%- for product in collection.products -%}
              {%- assign outer_index = forloop.index -%}
              {% render 'product-card', product: product, show_specs: s.show_specs %}
              {%- for block in promo_blocks -%}
                {%- if block.settings.position == outer_index -%}
                  {% render 'promo-card', block: block %}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" role="navigation" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="pagination__prev">
                  {% render 'icon', icon: 'chevron-left' %} Prev
                </a>
              {%- else -%}
                <span class="pagination__prev is-disabled">{% render 'icon', icon: 'chevron-left' %} Prev</span>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="pagination__page">{{ part.title }}</a>
                {%- elsif part.title == '…' -%}
                  <span class="pagination__ellipsis">…</span>
                {%- else -%}
                  <span class="pagination__page is-current">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="pagination__next">
                  Next {% render 'icon', icon: 'chevron-right' %}
                </a>
              {%- else -%}
                <span class="pagination__next is-disabled">Next {% render 'icon', icon: 'chevron-right' %}</span>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    { "type": "checkbox", "id": "show_specs", "label": "Show specs on cards", "default": true },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 48,
      "step": 6,
      "default": 24
    }
  ],
  "presets": [
    { "name": "Main collection" }
  ],
  "blocks": [
    {
      "type": "promo",
      "name": "Promo card",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Limited-time offer"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "info": "Optional. Short description under the heading."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 1200×2250px (8:15 portrait, matches actual rendered card aspect 367×687 ≈ 1:1.87) or larger. JPG/PNG/WebP. A 1:1 square image will be cropped ~37% vertically. Place the focal subject in the upper 60% of the image so the body text overlay at the bottom doesn't cover it."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Learn more",
          "info": "Single CTA — leave blank to hide the button."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Body alignment",
          "default": "bottom",
          "options": [
            {"value": "top", "label": "Top — all content at the top of the card"},
            {"value": "bottom", "label": "Bottom — all content at the bottom of the card"},
            {"value": "split", "label": "Split — heading at top, body and CTA at bottom"}
          ]
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font size",
          "default": "medium",
          "options": [
            {"value": "small", "label": "Small (heading 16px / text 12px)"},
            {"value": "medium", "label": "Medium (heading 20px / text 14px)"},
            {"value": "large", "label": "Large (heading 24px / text 16px)"},
            {"value": "xlarge", "label": "X-Large (heading 28px / text 18px)"}
          ]
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 100,
          "info": "Strength of the dark gradient behind the body text. 0 = no overlay (image fully visible), 100 = strongest dark (current default)."
        },
        {
          "type": "header",
          "content": "Position"
        },
        {
          "type": "range",
          "id": "position",
          "label": "Position",
          "min": 0,
          "max": 12,
          "step": 1,
          "default": 1,
          "info": "0 = render before the first product (top of grid). 1 = render after the 1st product. N = render after the Nth product."
        }
      ]
    }
  ]
}
{% endschema %}
