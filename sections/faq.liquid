{%- liquid
  assign s = section.settings
-%}

{%- style -%}
  .faq-{{ section.id }} {
    padding-top: {{ s.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ s.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .faq-{{ section.id }} {
      padding-top: {{ s.padding_top }}px;
      padding-bottom: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section section--faq faq-{{ section.id }} section--soft" {{ section.shopify_attributes }}>
  <div class="container faq-grid">
    <div class="faq-head">
      <h2 class="section__title">{{ s.heading }}</h2>
      {%- if s.subheading != blank -%}
        <p class="section__sub">{{ s.subheading }}</p>
      {%- endif -%}
      {%- if s.cta_text != blank -%}
        <a href="{{ s.cta_link }}" class="btn btn--outline">{{ s.cta_text }}</a>
      {%- endif -%}
    </div>
    <div class="faq-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <details class="faq__item" {{ block.shopify_attributes }}>
            <summary class="faq__q">
              <span>{{ block.settings.question }}</span>
              <span class="faq__icon">+</span>
            </summary>
            <div class="faq__a">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Before you buy"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Still have questions?"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?"
          }
        }
      ]
    }
  ]
}
{% endschema %}
