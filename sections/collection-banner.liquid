{%- liquid
  assign s = section.settings
  assign collection = s.collection | default: closest.collection

  assign has_image = false
  if s.image_desktop != blank
    assign has_image = true
  endif

  assign bg_style = ''
  if has_image
    assign bg_url = s.image_desktop | image_url: width: 2400
    assign bg_style = 'background-image: url(' | append: bg_url | append: ');'
  endif

  assign overlay_pct = s.overlay_opacity | divided_by: 100.0
-%}

<section
  class="collection-banner{% if has_image %} collection-banner--has-image{% endif %}"
  style="{{ bg_style }}"
  {{ section.shopify_attributes }}
>
  {%- if has_image and s.show_overlay -%}
    <div
      class="collection-banner__overlay"
      style="opacity: {{ overlay_pct }};"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  {%- if has_image and s.image_mobile != blank -%}
    <style>
      @media (max-width: 749px) {
        .collection-banner--has-image {
          background-image: url({{ s.image_mobile | image_url: width: 1200 }}) !important;
        }
      }
    </style>
  {%- endif -%}

  <div class="collection-banner__inner container">
    {%- if s.eyebrow != blank or collection.title -%}
      <span class="collection-banner__eyebrow">{{ s.eyebrow | default: collection.title }}</span>
    {%- endif -%}
    <h1 class="collection-banner__title">
      {%- if s.title != blank -%}
        {{ s.title }}
      {%- else -%}
        {{ collection.title }}
      {%- endif -%}
    </h1>
    {%- if s.subtitle != blank or collection.description != blank -%}
      <p class="collection-banner__sub">{{ s.subtitle | default: collection.description }}</p>
    {%- endif -%}
    {%- if s.show_count -%}
      <div class="collection-banner__count">
        <strong>{{ collection.products_count | default: paginate.items }}</strong> products
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "tag": "section",
  "class": "section-collection-banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "info": "Defaults to collection title" },
    { "type": "text", "id": "title", "label": "Title", "info": "Defaults to collection title" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "info": "Defaults to collection description" },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Falls back to desktop image when empty."
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Dark overlay on image",
      "default": true,
      "info": "Improves text readability over photos"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%",
      "info": "0% = no darken, 80% = nearly black"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    }
  ],
  "presets": [
    { "name": "Collection banner" }
  ]
}
{% endschema %}