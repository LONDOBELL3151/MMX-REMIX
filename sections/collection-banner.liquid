{%- liquid
  assign s = section.settings
  assign collection = s.collection | default: closest.collection

  # 背景图优先级: image_picker(强制覆盖) > collection.image(admin 给 collection 上传的封面图) > collection.featured_image(首个产品的图) > collection.products.first.featured_image
  assign bg_source = s.image_desktop
  if bg_source == blank and collection
    if collection.image
      assign bg_source = collection.image
    elsif collection.featured_image
      assign bg_source = collection.featured_image
    elsif collection.products.first and collection.products.first.featured_image
      assign bg_source = collection.products.first.featured_image
    endif
  endif

  assign has_image = false
  assign bg_style = ''
  if bg_source
    assign has_image = true
    assign bg_url = bg_source | image_url: width: 2400
    assign bg_style = 'background-image: url(' | append: bg_url | append: ');'
  endif

  assign overlay_pct = s.overlay_opacity | divided_by: 100.0
-%}

<section
  class="collection-banner{% if has_image %} collection-banner--has-image{% endif %}"
  style="{{ bg_style }}"
  {{ section.shopify_attributes }}
>
  {%- if has_image and s.show_overlay -%}
    <div
      class="collection-banner__overlay"
      style="--overlay-alpha: {{ overlay_pct }};"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  {%- if has_image and s.image_mobile != blank -%}
    <style>
      @media (max-width: 749px) {
        .collection-banner--has-image {
          background-image: url({{ s.image_mobile | image_url: width: 1200 }}) !important;
        }
      }
    </style>
  {%- endif -%}

  <div class="collection-banner__inner container">
    {%- if s.eyebrow != blank -%}
      <span class="collection-banner__eyebrow">{{ s.eyebrow }}</span>
    {%- elsif collection and collection.title -%}
      <span class="collection-banner__eyebrow">{{ collection.title }}</span>
    {%- endif -%}
    <h1 class="collection-banner__title">
      {%- if s.title != blank -%}
        {{ s.title }}
      {%- elsif collection -%}
        {{ collection.title }}
      {%- endif -%}
    </h1>
    {%- if s.subtitle != blank -%}
      <p class="collection-banner__sub">{{ s.subtitle }}</p>
    {%- endif -%}
    {%- if s.show_count -%}
      <div class="collection-banner__count">
        <strong>{{ collection.products_count | default: paginate.items }}</strong> products
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "tag": "section",
  "class": "section-collection-banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "info": "Defaults to collection title" },
    { "type": "text", "id": "title", "label": "Title", "info": "Defaults to collection title" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "info": "Optional. Leave blank to hide. Does not auto-pull collection description." },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image override (desktop)",
      "info": "Optional. Leave blank to use the collection's image (set in Shopify admin → Products → Collections → Collection image)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image override (mobile)",
      "info": "Optional. Falls back to desktop image when empty."
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Dark overlay on image",
      "default": true,
      "info": "Improves text readability over photos"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%",
      "info": "Direct black alpha: 0% = no darken (image fully visible), 100% = nearly black. Top of banner stays lighter, bottom goes darker for text readability."
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    }
  ],
  "presets": [
    { "name": "Collection banner" }
  ]
}
{% endschema %}