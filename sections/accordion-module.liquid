<script>
  var shogunAccordion = document.querySelectorAll('.shogun-accordion');
  var shogunAccordionBody = document.querySelectorAll('.shogun-accordion-body');
  var shogunAccordionIcon = document.querySelectorAll('.shogun-accordion .shogun-accordion-icon');

  shogunAccordion.forEach((e, i) => {
    let shogunAccordionHeader = e.firstElementChild;
    shogunAccordionHeader.addEventListener('click', (ele) => {
      addClass(i);
      if (shogunAccordionHeader.children.length > 0) {
        shogunAccordionHeader.children[1].classList.toggle('shogun-icon-chevron');
      }

      if (shogunAccordionHeader.parentNode.children.length > 1) {
        let ischeng = shogunAccordionHeader.parentNode.children[1].classList.toggle('shogun-accordion-active');
        let heights = shogunAccordionHeader.parentNode.children[1].children[0].offsetHeight;
        shogunAccordionHeader.parentNode.children[1].style.height = ischeng ? heights + 'px' : 0;
      }
      // 			ele.path[0].children[1].classList.toggle('shogun-icon-chevron')

      // 			let ischeng = ele.path[1].children[1].classList.toggle('shogun-accordion-active')
      // 			let heights = ele.path[1].children[1].children[0].offsetHeight
      // 			ele.path[1].children[1].style.height = ischeng ? heights + 'px' : 0
    });
  });

  function addClass(i) {
    shogunAccordionIcon.forEach((val, j) => {
      if (i != j) {
        val.className = 'shogun-accordion-icon';
      }
    });
    shogunAccordionBody.forEach((val, j) => {
      if (i != j) {
        val.className = 'shogun-accordion-body';
        val.style.height = '0';
      }
    });
  }
</script>

