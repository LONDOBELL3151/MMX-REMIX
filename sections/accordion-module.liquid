{% assign heading_font = section.settings.heading_font.family %}
{% assign content_font = section.settings.content_font.family %}
{% assign item_width = 100 | divided_by: section.settings.item_quantity %}

<style>
  {{ section.settings.heading_font | font_face }}
  {{ section.settings.content_font | font_face }}

  .shogun-accordion-wrapper {
    padding: 0 10px;
    box-sizing: border-box;
  }

  .shogun-accordion-wrapper{
  	width: 100%;
  	max-width: {{ section.settings.max_width }};
  	margin: {{ section.settings.pc_margin_top }}px auto {{ section.settings.pc_margin_bottom }}px;
  }
  .shogun-accordion {
  	border: 1px solid #ddd;
  	margin-top: 5px;
  	border-radius: 4px;
  	box-shadow: 0 1px 1px rgb(0, 0, 0, .05);
  	overflow: hidden;
  }

  .shogun-accordion-header {
  	background: #f5f5f5;
  	padding: 10px;
  	cursor: pointer;
  	display: flex;
  	align-items: center;
  	justify-content: space-between;
  	position: relative;
  	box-sizing: border-box;
  	font-family: {{ heading_font }};
  }

  .shogun-accordion-title {
  	color: #000;
  	font-weight: bold;
  	font-family: {{ heading_font }};
  	font-size: 20px;
  }

  .shogun-accordion-icon span {
  	color: #000;
  	font-size: 25px;
  	line-height: 25px;
  	display: flex;
  	justify-content: center;
  	align-items: center;
  	transition: 0.3s transform;
  	font-family: {{ heading_font }};
  }

  .shogun-accordion-icon span::after {
  	content: "▸";
  }

  .shogun-accordion-icon.shogun-icon-chevron span {
  	transform: rotate(90deg);
  	/* transition: 0.3s transform; */
  }


  .shogun-accordion-body {
  	border-top: 1px solid #ddd;
  	background-color: #fff;
  	opacity: 0;
  	transition: all .5s linear;
  	overflow: hidden;
  	height: 0;
  }

  .accordion-page {
  	display: flex;
  	align-items: flex-start;
  	justify-content: flex-start;
  	flex-wrap: wrap;
  	padding: 20px;
  	height: auto;
  	box-sizing: border-box;
    gap: 5px;
  }

  .shogun-content {
  	/* width: calc({{ item_width }}% - 20px);
  	flex-shrink: 0; */
    width: 33%
  }

  .shogun-accordion-active {
  	opacity: 1;
  	/* height: auto; */
  	visibility: visible;

  }

  .shg-theme-text-content {
  	font-size: 18px;
  	line-height: 24px;
  	margin-bottom: 18px;
  	color: #3c3c3c;
  	font-family: {{ content_font }};
  }

  .shg-theme-text-content:last-of-type {
  	font-size: 14px;
  	margin-bottom: 42px;
  }

  @media only screen and (max-width: 1038px) {
    .shogun-content {
      flex:auto;
    }
  }

  @media screen and (max-width: 767px) {
  	.shogun-accordion-wrapper{
  		margin: {{ section.settings.mb_margin_top }}px auto {{ section.settings.mb_margin_bottom }}px;
  	}

  	.accordion-page {
  		display: block;
  	}

  	.shogun-content {
  		width: 100%;
  	}
  	.shogun-accordion{
  		margin-left: 1%;
  		margin-right: 1%;
  	}
  }
</style>

<div class="shogun-accordion-wrapper">
