    <div class="shogun-accordion">
      <!-- Module Heading -->
      <div class="shogun-accordion-header">
        {% if block.settings.heading != blank %}
          <h4 class="shogun-accordion-title">
            {{ block.settings.heading }}
          </h4>
        {% endif %}

