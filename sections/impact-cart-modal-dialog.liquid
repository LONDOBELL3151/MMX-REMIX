<link rel="stylesheet" href="{{ 'impact-cart-modal-dialog.css' | asset_url }}">
<div class="impact-cart-modal-dialog_overlay"></div>
<div
  class="impact-cart-modal-dialog_wrapper"
  role="document"
>
  <button title="Close" type="button" class="impact-cart-modal-dialog_close" aria-label="Close">
    <span class="sr-only">Close</span>
    <span class="icon-close">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
        <path fill="currentColor" d="M764.288 214.592 512 466.88 259.712 214.592a31.936 31.936 0 0 0-45.12 45.12L466.752 512 214.528 764.224a31.936 31.936 0 1 0 45.12 45.184L512 557.184l252.288 252.288a31.936 31.936 0 0 0 45.12-45.12L557.12 512.064l252.288-252.352a31.936 31.936 0 1 0-45.12-45.184z"></path>
      </svg>
    </span>
  </button>

  <impact-cart-modal-dialog
    class="impact-cart-modal-dialog_content"
    id="impact-cart-modal-dialog"
    data-cart-count="{{ cart.item_count }}"
  >
    {%- if cart.item_count > 0 -%}
      <div class="impact-cart-modal-dialog_draw-head">
        <h3>Shopping Cart</h3>
        <p class="cart-draw_count">
          <span class="sr-only">{{ cart.item_count }} items</span>
          {{ cart.item_count }}
        </p>
      </div>

      <div class="impact-cart-modal-dialog_draw-content-wrapper">
        <div class="overflow-container">
          <div class="impact-cart-modal-dialog_draw-overflow-content">
            {%- if cart != empty -%}
              {%- for item in cart.items -%}
                {% liquid
                  assign current_bind = item.properties._bind | default: ''
                  assign current_grade = item.properties._grade | default: ''
                  assign current_index = forloop.index0
                  assign has_free_item = false
                  assign has_accessories = false
                %}
                {% for i in (current_index..cart.items.size) %}
                  {% assign next_index = i | plus: 1 %}
                  {% assign next_block = cart.items[next_index] | default: null %}

                  {% if next_block and next_block.properties._bind == current_bind %}
                    {% if next_block.price == 0 or next_block.price == '0' %}
                      {% assign has_free_item = true %}
                    {% else %}
                      {% assign has_accessories = true %}
                    {% endif %}
                  {% endif %}
                {% endfor %}

                {%- if current_bind == blank -%}
                  <div
                    class="cart-item"
                    id="impact-cart-modal-dialog-item-{{ forloop.index }}"
                    data-variant-id="{{ item.id }}"
                  >
                    <div class="cart-item_media">
                      <a href="{{ item.url }}">
                        {%- if item.image -%}
                          {{-
                            item.image
                            | image_url: width: item.image.width
                            | image_tag:
                              loading: 'lazy',
                              sizes: '(max-width: 740px) 80px, 96px',
                              widths: '80,96,160,192',
                              class: 'line-item__media'
                          -}}
                        {%- else -%}
                          {{-
                            'lifestyle-2'
                            | placeholder_svg_tag: 'placeholder'
                            | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"'
                          -}}
                        {%- endif -%}
                      </a>
                      <div class="loading_icon hidden" id="impact-cart-modal-loading-icon-{{ forloop.index }}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="spinner" viewBox="0 0 66 66">
                          <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" class="path"></circle>
                        </svg>
                      </div>
                    </div>
                    <div class="cart-item_details">
                      <div class="cart-item_header">
                        <a href="{{ item.url }}">
                          <p>{{- item.product.title | default: item.title -}}</p>
                        </a>
                      </div>
                      <div class="cart-item_price">
                        <div class="sale-price">
                          <span class="sr-only">Sale price</span>
                          <p>{{ item.final_price | money_with_currency }}</p>
                        </div>
                      </div>
                      {%- unless item.product.has_only_default_variant or item.gift_card -%}
                        <div class="cart-item_sku">
                          <p>{{ item.variant.title }}</p>
                        </div>
                      {%- endunless -%}

                      {%- if item.selling_plan_allocation -%}
                        <div class="cart-item_sku">
                          <p>{{ item.selling_plan_allocation.selling_plan.name }}</p>
                        </div>
                      {%- endif -%}
                    </div>
                    <div class="cart-item_qty">
                      <impact-cart-quantity-input class="quantity-input">
                        <button name="minus" type="button" aria-label="Reduce item quantity by one">
                          <span class="sr-only"
                            >Decrease quantity for
                            {{- item.product.title | escape -}}
                          </span>
                          <span class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
                              <path fill="currentColor" d="M128 544h768a32 32 0 1 0 0-64H128a32 32 0 0 0 0 64"></path>
                            </svg>
                          </span>
                        </button>
                        <input
                          data-quantity-variant-id="{{ item.variant.id }}"
                          class="quantity-num"
                          type="number"
                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                          min="0"
                          data-min="{{ item.variant.quantity_rule.min }}"
                          {% if item.variant.inventory_quantity %}
                            max="{{ item.variant.inventory_quantity }}"
                          {% endif %}
                          step="1"
                          aria-label="Quantity for {{ item.product.title | escape }}"
                          value="{{ item.quantity }}"
                          id="Quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                        >
                        <button name="plus" type="button" aria-label="Increase item quantity by one">
                          <span class="sr-only"
                            >Increase quantity for
                            {{- item.product.title | escape -}}
                          </span>
                          <span class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
                              <path fill="currentColor" d="M480 480V128a32 32 0 0 1 64 0v352h352a32 32 0 1 1 0 64H544v352a32 32 0 1 1-64 0V544H128a32 32 0 0 1 0-64z"></path>
                            </svg>
                          </span>
                        </button>
                      </impact-cart-quantity-input>
                      <impact-cart-item-remove class="cart-item__remove" data-idx="{{ forloop.index }}">
                        <a
                          href="{{ item.url_to_remove }}"
                          class="remove-link"
                          data-index="{{ forloop.index }}"
                          aria-label="Remove {{- item.product.title | default: item.title -}} - {{ item.variant.title }}"
                        >
                          <span class="icon-delete">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
                              <path fill="currentColor" d="M160 256H96a32 32 0 0 1 0-64h256V95.936a32 32 0 0 1 32-32h256a32 32 0 0 1 32 32V192h256a32 32 0 1 1 0 64h-64v672a32 32 0 0 1-32 32H192a32 32 0 0 1-32-32zm448-64v-64H416v64zM224 896h576V256H224zm192-128a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32m192 0a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32"></path>
                            </svg>
                          </span>
                        </a>
                      </impact-cart-item-remove>
                      <div class="cart-item-errors hidden">
                        <p></p>
                      </div>
                    </div>
                  </div>
                {%- else -%}
                  {%- if current_grade == 'classA' -%}
                    <div
                      class="cart-item bind-cart-item bind_product"
                      id="impact-cart-modal-dialog-item-{{ forloop.index }}"
                      data-variant-id="{{ item.id }}"
                    >
                      <div class="cart-item_media">
                        <a href="{{ item.url }}">
                          {%- if item.image -%}
                            {{-
                              item.image
                              | image_url: width: item.image.width
                              | image_tag:
                                loading: 'lazy',
                                sizes: '(max-width: 740px) 80px, 96px',
                                widths: '80,96,160,192',
                                class: 'line-item__media'
                            -}}
                          {%- else -%}
                            {{-
                              'lifestyle-2'
                              | placeholder_svg_tag: 'placeholder'
                              | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"'
                            -}}
                          {%- endif -%}
                        </a>
                        <div class="loading_icon hidden" id="impact-cart-modal-loading-icon-{{ forloop.index }}">
                          <svg xmlns="http://www.w3.org/2000/svg" class="spinner" viewBox="0 0 66 66">
                            <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" class="path"></circle>
                          </svg>
                        </div>
                      </div>
                      <div class="cart-item_details">
                        <div class="cart-item_header">
                          <a href="{{ item.url }}">
                            <p>{{- item.product.title | default: item.title -}}</p>
                          </a>
                        </div>
                        <div class="cart-item_price">
                          <div class="sale-price">
                            <span class="sr-only">Sale price</span>
                            <p>{{ item.final_price | money_with_currency }}</p>
                          </div>
                        </div>
                        {%- unless item.product.has_only_default_variant or item.gift_card -%}
                          <div class="cart-item_sku">
                            <p>{{ item.variant.title }}</p>
                          </div>
                        {%- endunless -%}

                        {%- if item.selling_plan_allocation -%}
                          <div class="cart-item_sku">
                            <p>{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          </div>
                        {%- endif -%}

                        {%- if has_free_item -%}
                          <div class="bind_product-fold bind_product_fold-free">
                            {%- assign id_fold = 'id_fold-' | append: current_bind -%}
                            <input hidden type="checkbox" id="{{ id_fold }}" checked>
                            <label for="{{ id_fold }}">Free Gift</label>

                            <div class="bind_product_fold-sub">
                              <ul>
                                {% for i in (current_index..cart.items.size) %}
                                  {% assign next_index = i | plus: 1 %}
                                  {% assign next_block = cart.items[next_index] | default: null %}

                                  {% liquid
                                    assign next_link = next_block.properties._link | default: ''
                                    assign bing_title = next_block.product.title | default: ''
                                  %}

                                  {% if next_block
                                    and next_block.properties._bind == current_bind
                                    and next_block.price == 0
                                  %}
                                    <li
                                      data-bind="{{ next_block.properties._bind }}"
                                      data-variant-id="{{ next_block.variant_id }}"
                                      class="bind_product_fold-sub-li"
                                    >
                                      <div style="display: none;">{{ next_block | json }}</div>
                                      <div class="bind_product_fold-details">
                                        <div class="bind_product_fold-details-media">
                                          {%- capture img_content -%}
                                            {%- if next_block.image -%}
                                              <img
                                              src="{{ next_block.image | image_url: width: 300 }}"
                                              class="cart-item__image"
                                              alt="{{ next_block.image.alt | escape }}"
                                              loading="lazy"
                                              width="150"
                                              height="{{ 150 | divided_by: next_block.image.aspect_ratio | ceil }}"
                                            >
                                            {%- else -%}
                                            {{
                                              'hero-apparel-1'
                                              | placeholder_svg_tag: 'placeholder'
                                              | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"'
                                            }}
                                            {%- endif -%}
                                          {%- endcapture -%}
                                          {%- if next_link != blank -%}
                                            <a
                                              href="{{ next_link }}"
                                              aria-label="{{ bing_title | escape }}"
                                            >
                                              {{ img_content }}
                                            </a>
                                          {%- else -%}
                                            {{ img_content }}
                                          {%- endif -%}
                                          <div
                                            class="loading_icon hidden"
                                            id="impact-cart-modal-loading-icon-{{ next_block.index | plus: 1 }}"
                                          >
                                            <svg xmlns="http://www.w3.org/2000/svg" class="spinner" viewBox="0 0 66 66">
                                              <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" class="path"></circle>
                                            </svg>
                                          </div>
                                        </div>
                                        <div class="bind_product_fold-details-info">
                                          {%- if next_link != blank -%}
                                            <a href="{{ next_link }}">
                                              <p class="bind-title">{{ bing_title }}</p>
                                            </a>
                                          {%- else -%}
                                            <p class="bind-title">{{ bing_title }}</p>
                                          {%- endif -%}
                                          {% if next_block.price == 0 or next_block.price == '0' %}
                                            <p class="bind-price bind-price-text">FREE</p>
                                            
                                          {% else %}
                                            <p class="bind-price">
                                              <span class="sr-only">Sale Price</span>
                                              {{ next_block.price | money }}
                                            </p>
                                          {% endif %}
                                          {%- if next_block.product.has_only_default_variant == false -%}
                                            <p class="variant-option">
                                              {{ next_block.variant.title }}
                                            </p>
                                          {%- endif -%}
                                        </div>
                                      </div>
                                      <div class="bind_product_fold-details-remove">
                                        <p class="quantity-num">{{ next_block.quantity }}</p>

                                        <impact-cart-item-remove
                                          id="Remove-{{ next_block.index | plus: 1 }}"
                                          data-index="{{ next_block.index | plus: 1 }}"
                                          data-idx="{{ next_block.index | plus: 1 }}"
                                        >
                                          <a
                                            href="{{ next_block.url_to_remove }}"
                                            class="button button--tertiary"
                                            aria-label="{{ 'sections.cart.remove_title' | t: title: next_block.title | escape }}"
                                          >
                                            <span class="svg-wrapper">
                                              <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 1024 1024"
                                                data-v-d2e47025=""
                                              >
                                                <path fill="currentColor" d="M160 256H96a32 32 0 0 1 0-64h256V95.936a32 32 0 0 1 32-32h256a32 32 0 0 1 32 32V192h256a32 32 0 1 1 0 64h-64v672a32 32 0 0 1-32 32H192a32 32 0 0 1-32-32zm448-64v-64H416v64zM224 896h576V256H224zm192-128a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32m192 0a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32"></path>
                                              </svg>
                                            </span>
                                          </a>
                                        </impact-cart-item-remove>
                                      </div>
                                    </li>
                                  {% endif %}
                                {% endfor %}
                              </ul>
                            </div>
                          </div>
                        {%- endif -%}

                        {%- if has_accessories -%}
                          <div class="bind_product-fold">
                            {%- assign id_bind = 'id_bind-' | append: current_bind -%}
                            <input hidden type="checkbox" id="{{ id_bind }}" checked>
                            <label for="{{ id_bind }}">Accessories</label>
                            <div class="bind_product_fold-sub">
                              <ul>
                                {% for i in (current_index..cart.items.size) %}
                                  {% assign next_index = i | plus: 1 %}
                                  {% assign next_block = cart.items[next_index] | default: null %}

                                  {% liquid
                                    assign next_link = next_block.properties._link | default: ''
                                    assign bing_title = next_block.product.title | default: ''
                                  %}

                                  {% if next_block
                                    and next_block.properties._bind == current_bind
                                    and next_block.price != 0
                                  %}
                                    <li
                                      data-bind="{{ next_block.properties._bind }}"
                                      data-variant-id="{{ next_block.variant_id }}"
                                      class="bind_product_fold-sub-li"
                                    >
                                      <div style="display: none;">{{ next_block | json }}</div>
                                      <div class="bind_product_fold-details">
                                        <div class="bind_product_fold-details-media">
                                          {%- capture img_content -%}
                                            {%- if next_block.image -%}
                                              <img
                                              src="{{ next_block.image | image_url: width: 300 }}"
                                              class="cart-item__image"
                                              alt="{{ next_block.image.alt | escape }}"
                                              loading="lazy"
                                              width="150"
                                              height="{{ 150 | divided_by: next_block.image.aspect_ratio | ceil }}"
                                            >
                                            {%- else -%}
                                            {{
                                              'hero-apparel-1'
                                              | placeholder_svg_tag: 'placeholder'
                                              | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"'
                                            }}
                                            {%- endif -%}
                                          {%- endcapture -%}
                                          {%- if next_link != blank -%}
                                            <a
                                              href="{{ next_link }}"
                                              aria-label="{{ bing_title | escape }}"
                                            >
                                              {{ img_content }}
                                            </a>
                                          {%- else -%}
                                            {{ img_content }}
                                          {%- endif -%}
                                          <div
                                            class="loading_icon hidden"
                                            id="impact-cart-modal-loading-icon-{{ next_block.index | plus: 1 }}"
                                          >
                                            <svg xmlns="http://www.w3.org/2000/svg" class="spinner" viewBox="0 0 66 66">
                                              <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" class="path"></circle>
                                            </svg>
                                          </div>
                                        </div>
                                        <div class="bind_product_fold-details-info">
                                          {%- if next_link != blank -%}
                                            <a href="{{ next_link }}">
                                              <p class="bind-title">{{ bing_title }}</p>
                                            </a>
                                          {%- else -%}
                                            <p class="bind-title">{{ bing_title }}</p>
                                          {%- endif -%}
                                          {% if next_block.price == 0 or next_block.price == '0' %}
                                            <p class="bind-price bind-price-text">FREE</p>
                                            
                                          {% else %}
                                            <p class="bind-price">
                                              <span class="sr-only">Sale Price</span>
                                              {{ next_block.price | money }}
                                            </p>
                                          {% endif %}
                                          {%- if next_block.product.has_only_default_variant == false -%}
                                            <p class="variant-option">
                                              {{ next_block.variant.title }}
                                            </p>
                                          {%- endif -%}
                                        </div>
                                      </div>
                                      <div class="bind_product_fold-details-remove">
                                        <p class="quantity-num">{{ next_block.quantity }}</p>

                                        <impact-cart-item-remove
                                          id="Remove-{{ next_block.index | plus: 1 }}"
                                          data-index="{{ next_block.index | plus: 1 }}"
                                          data-idx="{{ next_block.index | plus: 1 }}"
                                        >
                                          <a
                                            href="{{ next_block.url_to_remove }}"
                                            class="button button--tertiary"
                                            aria-label="{{ 'sections.cart.remove_title' | t: title: next_block.title | escape }}"
                                          >
                                            <span class="svg-wrapper">
                                              <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 1024 1024"
                                                data-v-d2e47025=""
                                              >
                                                <path fill="currentColor" d="M160 256H96a32 32 0 0 1 0-64h256V95.936a32 32 0 0 1 32-32h256a32 32 0 0 1 32 32V192h256a32 32 0 1 1 0 64h-64v672a32 32 0 0 1-32 32H192a32 32 0 0 1-32-32zm448-64v-64H416v64zM224 896h576V256H224zm192-128a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32m192 0a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32"></path>
                                              </svg>
                                            </span>
                                          </a>
                                        </impact-cart-item-remove>
                                      </div>
                                    </li>
                                  {% endif %}
                                {% endfor %}
                              </ul>
                            </div>
                          </div>
                        {%- endif -%}
                      </div>
                      <div class="cart-item_qty">
                        <p class="bind-cart_quantity">{{ item.quantity }}</p>
                        <impact-cart-item-remove
                          class="cart-item__remove"
                          data-idx="{{ forloop.index }}"
                          data-grade="{{ current_grade }}"
                          data-bind="{{ current_bind }}"
                          data-variant-id="{{ item.variant_id }}"
                        >
                          <a
                            href="{{ item.url_to_remove }}"
                            class="remove-link"
                            data-index="{{ forloop.index }}"
                            aria-label="Remove {{- item.product.title | default: item.title -}} - {{ item.variant.title }}"
                          >
                            <span class="icon-delete">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
                                <path fill="currentColor" d="M160 256H96a32 32 0 0 1 0-64h256V95.936a32 32 0 0 1 32-32h256a32 32 0 0 1 32 32V192h256a32 32 0 1 1 0 64h-64v672a32 32 0 0 1-32 32H192a32 32 0 0 1-32-32zm448-64v-64H416v64zM224 896h576V256H224zm192-128a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32m192 0a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32"></path>
                              </svg>
                            </span>
                          </a>
                        </impact-cart-item-remove>
                        <div class="cart-item-errors hidden">
                          <p></p>
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              <impact-cart-dialog-button
                class="impact-cart-modal-dialog_clear-cart"
                aria-label="Clear shopping cart"
              >
                <span aria-hidden="true" class="icon-del_cart">
                  <svg class="icon-cart" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-9a20e128="">
                    <path fill="currentColor" d="M432 928a48 48 0 1 1 0-96 48 48 0 0 1 0 96m320 0a48 48 0 1 1 0-96 48 48 0 0 1 0 96M96 128a32 32 0 0 1 0-64h160a32 32 0 0 1 31.36 25.728L320.64 256H928a32 32 0 0 1 31.296 38.72l-96 448A32 32 0 0 1 832 768H384a32 32 0 0 1-31.36-25.728L229.76 128zm314.24 576h395.904l82.304-384H333.44l76.8 384z"></path>
                  </svg>
                  <svg
                    class="icon-remove"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 1024 1024"
                    data-v-9a20e128=""
                  >
                    <path fill="currentColor" d="m466.752 512-90.496-90.496a32 32 0 0 1 45.248-45.248L512 466.752l90.496-90.496a32 32 0 1 1 45.248 45.248L557.248 512l90.496 90.496a32 32 0 1 1-45.248 45.248L512 557.248l-90.496 90.496a32 32 0 0 1-45.248-45.248z"></path><path fill="currentColor" d="M512 896a384 384 0 1 0 0-768 384 384 0 0 0 0 768m0 64a448 448 0 1 1 0-896 448 448 0 0 1 0 896"></path>
                  </svg>
                </span>
                <span aria-hidden="true" class="icon-loading">
                  <svg xmlns="http://www.w3.org/2000/svg" class="spinner" viewBox="0 0 66 66">
                    <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" class="path"></circle>
                  </svg>
                </span>
                Clear Cart
              </impact-cart-dialog-button>
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="impact-cart-modal-dialog_draw-footer">
        <div class="price_total">
          <p>Total</p>
          <p>{{- cart.total_price | money_with_currency -}}</p>
        </div>
        <p class="text">Tax included and shipping calculated at checkout</p>
        <form action="{{ routes.cart_url }}" method="POST" class="impact-cart-modal-dialog_draw-footer_buy">
          <a href="{{ routes.cart_url }}" class="viewCart-btn btn"> View cart </a>

          <button type="submit" class="checkout-btn btn" name="checkout">
            <div class="checkout-btn-text">
              <span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" data-v-d2e47025="">
                  <path fill="currentColor" d="M224 448a32 32 0 0 0-32 32v384a32 32 0 0 0 32 32h576a32 32 0 0 0 32-32V480a32 32 0 0 0-32-32zm0-64h576a96 96 0 0 1 96 96v384a96 96 0 0 1-96 96H224a96 96 0 0 1-96-96V480a96 96 0 0 1 96-96"></path><path fill="currentColor" d="M512 544a32 32 0 0 1 32 32v192a32 32 0 1 1-64 0V576a32 32 0 0 1 32-32m192-160v-64a192 192 0 1 0-384 0v64zM512 64a256 256 0 0 1 256 256v128H256V320A256 256 0 0 1 512 64"></path>
                </svg>
              </span>
              <span>Checkout</span>
            </div>
          </button>
        </form>
      </div>
    {%- else -%}
      <div class="impact-cart-modal-dialog_empty">
        <div class="cart-zero">
          <div class="icon-box">
            <span class="sr-only">Shopping Cart</span>
            <span class="icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                xml:space="preserve"
                style="enable-background:new 0 0 1024 1024;"
                viewBox="0 0 1024 1024"
                data-v-d2e47025=""
              >
                <path fill="currentColor" d="M887.01 264.99c-6-5.99-13.67-8.99-23.01-8.99H704c-1.34-54.68-20.01-100.01-56-136s-81.32-54.66-136-56c-54.68 1.34-100.01 20.01-136 56s-54.66 81.32-56 136H160c-9.35 0-17.02 3-23.01 8.99-5.99 6-8.99 13.67-8.99 23.01v640c0 9.35 2.99 17.02 8.99 23.01S150.66 960 160 960h704c9.35 0 17.02-2.99 23.01-8.99S896 937.34 896 928V288c0-9.35-2.99-17.02-8.99-23.01M421.5 165.5c24.32-24.34 54.49-36.84 90.5-37.5 35.99.68 66.16 13.18 90.5 37.5s36.84 54.49 37.5 90.5H384c.68-35.99 13.18-66.16 37.5-90.5M832 896H192V320h128v128h64V320h256v128h64V320h128z"></path>
              </svg>
            </span>
          </div>
          <p class="cart-draw_empty_count">0</p>
        </div>
        <p class="cart-draw_empty_text">Your cart is empty</p>
        <a href="{{ section.settings.impact_cart_empty_button_link }}" class="cart-draw_empty_href"
          >Continue shopping</a
        >
      </div>
    {%- endif -%}
  </impact-cart-modal-dialog>
</div>

