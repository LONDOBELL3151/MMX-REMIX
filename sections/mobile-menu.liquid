{%- comment -%}
  Reserved for future settings.
{%- endcomment -%}

<aside id="MobileMenu" class="mobile-menu" aria-hidden="true" data-mobile-menu>
  <div class="mobile-menu__overlay" data-mobile-menu-close></div>
  <div class="mobile-menu__panel">
    <div class="mobile-menu__header">
      <span class="mobile-menu__title">{{ 'general.menu' | t | default: 'Menu' }}</span>
      <button type="button" class="mobile-menu__close" data-mobile-menu-close aria-label="Close menu">
        {% render 'icon', icon: 'close' %}
      </button>
    </div>

    <nav class="mobile-menu__nav">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_link' -%}
          <a href="{{ block.settings.link }}" class="mobile-menu__item" {{ block.shopify_attributes }}>
            {{ block.settings.label }}
            {% render 'icon', icon: 'chevron-right' %}
          </a>
        {%- elsif block.type == 'menu' -%}
          {%- assign menu = block.settings.menu -%}
          {%- if menu != blank -%}
            <details class="mobile-menu__group" {{ block.shopify_attributes }}>
              <summary class="mobile-menu__item">
                {{ block.settings.label }}
                {% render 'icon', icon: 'chevron-down' %}
              </summary>
              <div class="mobile-menu__submenu">
                {%- for link in menu.links -%}
                  <a href="{{ link.url }}" class="mobile-menu__subitem">{{ link.title }}</a>
                {%- endfor -%}
              </div>
            </details>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="mobile-menu__footer">
      <a href="{{ routes.account_url }}" class="mobile-menu__account">
        {% render 'icon', icon: 'user' %}
        {{ 'customer.account.title' | t | default: 'Account' }}
      </a>
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Mobile menu",
  "tag": "aside",
  "class": "section-mobile-menu",
  "settings": [],
  "blocks": [
    {
      "type": "menu_link",
      "name": "Menu link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Link" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "menu",
      "name": "Dropdown menu",
      "settings": [
        { "type": "text", "id": "label", "label": "Trigger label", "default": "Menu" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ]
}
{% endschema %}
