{%- comment -%}
  Reserved for future settings.
{%- endcomment -%}

<section class="trust" aria-label="Why shop with us" {{ section.shopify_attributes }}>
  <div class="container trust__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'item' -%}
        <div class="trust__item" {{ block.shopify_attributes }}>
          <div class="trust__icon">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}{% render 'icon', icon: 'truck', size: 28 %}
              {%- when 'shield' -%}{% render 'icon', icon: 'shield', size: 28 %}
              {%- when 'calendar' -%}{% render 'icon', icon: 'calendar', size: 28 %}
              {%- when 'phone' -%}{% render 'icon', icon: 'phone', size: 28 %}
              {%- when 'lock' -%}{% render 'icon', icon: 'lock', size: 28 %}
              {%- when 'check' -%}{% render 'icon', icon: 'check', size: 28 %}
              {%- else -%}{% render 'icon', icon: 'check', size: 28 %}
            {%- endcase -%}
          </div>
          <div>
            <div class="trust__title">{{ block.settings.title }}</div>
            <div class="trust__sub">{{ block.settings.subtitle }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "tag": "section",
  "class": "section-trust",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F7F7F5"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "shield", "label": "Shield (Warranty)" },
            { "value": "calendar", "label": "Calendar (Trial)" },
            { "value": "phone", "label": "Phone (Support)" },
            { "value": "lock", "label": "Lock (Secure)" },
            { "value": "check", "label": "Check (Generic)" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Ships within 2 business days" }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      { "type": "item", "settings": { "icon": "truck", "title": "Free Shipping", "subtitle": "Ships within 2 business days" } },
      { "type": "item", "settings": { "icon": "shield", "title": "UL Certified", "subtitle": "In accordance with UL 2849" } },
      { "type": "item", "settings": { "icon": "calendar", "title": "14-Day Free Trial", "subtitle": "Buy with confidence" } },
      { "type": "item", "settings": { "icon": "phone", "title": "2-Year Warranty", "subtitle": "US-based support team" } }
    ]
  }
}
{% endschema %}
