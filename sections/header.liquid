{%- liquid
  assign s = section.settings
  assign logo_height = s.logo_height | default: settings.logo_height | default: 52
  assign logo_height_mobile = s.logo_height_mobile | default: settings.logo_height_mobile | default: 36
-%}

<header class="header{% if s.sticky_header %} header--sticky{% endif %}" role="banner" {{ section.shopify_attributes }}>
  <div class="container header__inner">
    <button type="button" class="icon-btn menu-toggle" aria-label="Open menu" data-mobile-menu-toggle>
      {% render 'icon', icon: 'menu' %}
    </button>

    <a href="{{ routes.root_url }}" class="logo logo--img" aria-label="{{ shop.name | escape }} home">
      {%- if s.logo != blank -%}
        <img src="{{ s.logo | image_url: width: 600 }}"
             srcset="{{ s.logo | image_url: width: 300 }} 300w, {{ s.logo | image_url: width: 600 }} 600w"
             sizes="(max-width: 560px) {{ logo_height_mobile }}px, {{ logo_height }}px"
             alt="{{ s.logo.alt | default: shop.name | escape }}"
             loading="eager"
             width="{{ logo_height | times: 3 }}"
             height="{{ logo_height }}">
      {%- elsif settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 600 }}"
             srcset="{{ settings.logo | image_url: width: 300 }} 300w, {{ settings.logo | image_url: width: 600 }} 600w"
             sizes="(max-width: 560px) {{ logo_height_mobile }}px, {{ logo_height }}px"
             alt="{{ settings.logo.alt | default: shop.name | escape }}"
             loading="eager"
             width="{{ logo_height | times: 3 }}"
             height="{{ logo_height }}">
      {%- else -%}
        <span class="logo__text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="nav" aria-label="Primary">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          {%- assign menu = block.settings.menu -%}
          {%- if menu != blank -%}
            {%- for link in menu.links -%}
              {%- if link.links.size > 0 -%}
                {%- assign submenu_id = 'nav-submenu-' | append: link.title | handleize | append: '-' | append: section.id -%}
                <div class="nav__menu">
                  <button type="button"
                          class="nav__item nav__item--has-sub{% if block.settings.accent %} nav__item--accent{% endif %}"
                          data-nav-toggle="{{ submenu_id }}"
                          aria-expanded="false"
                          aria-controls="{{ submenu_id }}">
                    {{ link.title }}
                    <svg class="nav__chevron" viewBox="0 0 10 6" aria-hidden="true" focusable="false" width="10" height="6"><path d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"/></svg>
                  </button>
                  <div id="{{ submenu_id }}"
                       class="nav__submenu"
                       data-nav-submenu
                       aria-hidden="true"
                       aria-label="{{ link.title | escape }}">
                    {%- for child_link in link.links -%}
                      <a href="{{ child_link.url }}" class="nav__subitem">{{ child_link.title | escape }}</a>
                    {%- endfor -%}
                  </div>
                </div>
              {%- else -%}
                <a href="{{ link.url }}" class="nav__item{% if block.settings.accent %} nav__item--accent{% endif %}"
                   {{ block.shopify_attributes }}>
                  {{ link.title }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="header__actions">
      {%- if s.show_search -%}
        <button type="button" class="icon-btn" aria-label="Search" data-search-toggle>
          {% render 'icon', icon: 'search' %}
        </button>
      {%- endif -%}

      {%- if s.show_account -%}
        <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
          {% render 'icon', icon: 'user' %}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="cart-btn" aria-label="Cart, {{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}" data-cart-count-wrap>
        {% render 'icon', icon: 'cart' %}
        <span>Cart (<span data-cart-count>{{ cart.item_count }}</span>)</span>
      </a>
    </div>
  </div>
</header>

{%- comment -%} Mobile menu (slides in from left on small screens, mirrors the desktop main-menu) {%- endcomment -%}
<aside id="MobileMenu" class="mobile-menu" aria-hidden="true" data-mobile-menu>
  <div class="mobile-menu__overlay" data-mobile-menu-close></div>
  <div class="mobile-menu__panel">
    <div class="mobile-menu__header">
      <span class="mobile-menu__title">Menu</span>
      <button type="button" class="mobile-menu__close" data-mobile-menu-close aria-label="Close menu">
        {% render 'icon', icon: 'close' %}
      </button>
    </div>
    <nav class="mobile-menu__nav" aria-label="Mobile primary">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          {%- assign menu = block.settings.menu -%}
          {%- if menu != blank -%}
            {%- for link in menu.links -%}
              {%- if link.links.size > 0 -%}
                <details class="mobile-menu__group">
                  <summary class="mobile-menu__item">
                    <span>{{ link.title }}</span>
                    {% render 'icon', icon: 'chevron-down' %}
                  </summary>
                  <div class="mobile-menu__submenu">
                    {%- for child_link in link.links -%}
                      <a href="{{ child_link.url }}" class="mobile-menu__subitem">{{ child_link.title | escape }}</a>
                    {%- endfor -%}
                  </div>
                </details>
              {%- else -%}
                <a href="{{ link.url }}" class="mobile-menu__item">
                  <span>{{ link.title }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </nav>
    <div class="mobile-menu__footer">
      <a href="{{ routes.account_url }}" class="mobile-menu__account">
        {% render 'icon', icon: 'user' %}
        <span>Account</span>
      </a>
    </div>
  </div>
</aside>

<style>
  .header .logo--img img {
    height: {{ logo_height }}px;
    width: auto;
    display: block;
    {%- if settings.logo_invert or s.logo_invert -%}
    filter: invert(1);
    {%- endif -%}
  }
  @media screen and (max-width: 749px) {
    .header .logo--img img {
      height: {{ logo_height_mobile }}px;
    }
  }
  {%- if s.sticky_header -%}
  /* Sticky header: section wrapper must be sticky too, because the header's
     containing block for sticky is the 77px section, which can't contain a
     sticky element taller than itself. Making the section sticky gives the
     body as the containing block (~9000px). */
  .shopify-section.section-header:has(> .header--sticky){position:sticky;top:0;z-index:100;background:#fff}
  {%- endif -%}
</style>
{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Override logo image (leave blank to use theme setting)"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Override logo height (px)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 52
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Override mobile logo height (px)",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "logo_invert",
      "label": "Invert this header's logo",
      "default": false
    },
    {
      "type": "header",
      "content": "Sticky behavior"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "default", "label": "Default (light)" },
        { "value": "inverse", "label": "Inverse (dark)" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "accent",
          "label": "Highlight links (yellow background)",
          "default": false,
          "info": "Applies a yellow background to every link in this menu."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "menu": "main-menu"
          }
        }
      ]
    }
  ]
}
{% endschema %}
