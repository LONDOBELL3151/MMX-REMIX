{{ 'section-why-features-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign collection = s.collection | default: closest.collection
-%}

<section
  class="wfg-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  {{ section.shopify_attributes }}
>
  <div class="container">
    <div class="wfg-card">

      <div class="wfg-card__text">
        {%- if s.eyebrow != blank -%}
          <span class="wfg-card__eyebrow">{{ s.eyebrow }}</span>
        {%- elsif collection and collection.title -%}
          <span class="wfg-card__eyebrow">{{ collection.title | upcase }}</span>
        {%- endif -%}

        <h2 class="wfg-card__title">
          {%- if s.heading != blank -%}
            {{ s.heading }}
          {%- elsif collection -%}
            Why Choose {{ collection.title }}?
          {%- else -%}
            Why Choose Us
          {%- endif -%}
        </h2>

        {%- if s.subtitle != blank -%}
          <p class="wfg-card__sub">{{ s.subtitle }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="wfg-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <div class="wfg-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.custom_icon != blank or block.settings.icon != blank -%}
                    <div class="wfg-item__icon">
                      {%- if block.settings.custom_icon != blank -%}
                        <img
                          src="{{ block.settings.custom_icon | image_url: width: 96 }}"
                          alt="{{ block.settings.title | escape }}"
                          width="48"
                          height="48"
                          loading="lazy"
                        >
                      {%- else -%}
                        {% render 'icon-feature', icon: block.settings.icon, size: 48 %}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  <h3 class="wfg-item__title">{{ block.settings.title }}</h3>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="wfg-card__media">
        {%- if s.image != blank -%}
          <img
            class="wfg-card__img"
            src="{{ s.image | image_url: width: 1200 }}"
            srcset="
              {%- if s.image.width >= 600 -%}{{ s.image | image_url: width: 600 }} 600w,{%- endif -%}
              {%- if s.image.width >= 800 -%}{{ s.image | image_url: width: 800 }} 800w,{%- endif -%}
              {%- if s.image.width >= 1200 -%}{{ s.image | image_url: width: 1200 }} 1200w,{%- endif -%}
              {{ s.image | image_url }} {{ s.image.width }}w
            "
            sizes="(min-width: 990px) 42vw, 100vw"
            alt="{{ s.image.alt | default: s.heading | escape }}"
            width="{{ s.image.width }}"
            height="{{ s.image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'wfg-card__img' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why features grid",
  "tag": "section",
  "class": "section-why-features-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small uppercase label above the title. Defaults to collection title."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Defaults to 'Why Choose [Collection Title]?'"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Short description paragraph above the feature grid."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right-side image",
      "info": "Recommended 1200x900 (4:3) or 1200x1200. Will be cover-cropped to fill the right column."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon (upload)",
          "info": "Upload a PNG or pick from /assets/ theme assets. Overrides the built-in icon below."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Built-in icon (fallback)",
          "options": [
            { "value": "compact", "label": "Compact / Folding" },
            { "value": "storage", "label": "Storage / Capacity" },
            { "value": "money", "label": "Money / Savings" },
            { "value": "check", "label": "Checkmark / Verified" },
            { "value": "eco", "label": "Eco / Sustainable" },
            { "value": "power", "label": "Power / Battery" }
          ],
          "default": "check",
          "info": "Used only when no custom icon is uploaded. Legacy blocks still pointing at this stay rendered."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Why features grid",
      "blocks": [
        { "type": "feature", "settings": { "icon": "2-year-warranty.png", "title": "2-Year Warranty" } },
        { "type": "feature", "settings": { "icon": "Free-Shipping.png", "title": "Free Shipping" } },
        { "type": "feature", "settings": { "icon": "Installment-Payment.png", "title": "Installment Payment" } },
        { "type": "feature", "settings": { "icon": "Trusted.png", "title": "Trusted by Riders" } },
        { "type": "feature", "settings": { "icon": "UL-CERTIFIED.png", "title": "UL Certified" } },
        { "type": "feature", "settings": { "icon": "Unbeatable-Value.png", "title": "Unbeatable Value" } }
      ]
    }
  ]
}
{% endschema %}
