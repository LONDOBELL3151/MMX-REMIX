{%- liquid
  assign s = section.settings
-%}

{%- if s.show_bar -%}
  <div class="announcement" role="region" aria-label="{{ s.aria_label | escape }}" {{ section.shopify_attributes }}>
    <div class="announcement__track" {% if s.enable_marquee %}data-marquee{% endif %}>
      {%- for block in section.blocks -%}
        {%- if block.type == 'announcement' -%}
          <span class="announcement__item announcement__item--legacy color-{{ block.settings.color_scheme | default: 'background-2' }}{% if block.settings.text_alignment %} announcement__item--{{ block.settings.text_alignment }}{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">
                <span class="announcement__dot">·</span>
                {{ block.settings.text }}
              </a>
            {%- else -%}
              <span class="announcement__dot">·</span>
              {{ block.settings.text }}
            {%- endif -%}
          </span>
        {%- else -%}
          <span class="announcement__item" {{ block.shopify_attributes }}>
            <span class="announcement__dot">·</span>
            {{ block.settings.text }}
          </span>
        {%- endif -%}
      {%- endfor -%}
      {%- if section.blocks.size == 0 -%}
        <span class="announcement__item"><span class="announcement__dot">·</span> {{ s.default_text }}</span>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_marquee",
      "label": "Enable scrolling marquee",
      "default": true
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Aria label",
      "default": "Announcements"
    },
    {
      "type": "text",
      "id": "default_text",
      "label": "Default text (when no blocks)",
      "default": "FREE Shipping on All eBikes - Ships from US Warehouse"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "FREE Shipping on All eBikes - Ships from US Warehouse"
        }
      ]
    },
    {
      "type": "announcement",
      "name": "Announcement (legacy)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "color_scheme",
          "label": "Color scheme",
          "default": "background-2",
          "options": [
            { "value": "background-1", "label": "Background 1" },
            { "value": "background-2", "label": "Background 2" },
            { "value": "accent-1", "label": "Accent 1" },
            { "value": "accent-2", "label": "Accent 2" }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "default": {
    "blocks": [
      { "type": "message" },
      { "type": "message", "settings": { "text": "14-Day Free Trial - Ride It, Love It or Return It" } },
      { "type": "message", "settings": { "text": "UL 2849 Certified Battery - Ride with Confidence" } },
      { "type": "message", "settings": { "text": "2-Year Warranty + US-Based Support Team" } }
    ]
  }
}
{% endschema %}
