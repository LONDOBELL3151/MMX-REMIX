{%- liquid
  assign s = section.settings
-%}

<section class="about-floating-stats" {{ section.shopify_attributes }}>
  <div class="container about-floating-stats__wrap">
    {%- for block in section.blocks -%}
      {%- if block.type == 'stat' -%}
        <div class="about-floating-stat" {{ block.shopify_attributes }}>
          <div class="about-floating-stat__icon">
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="100" height="100">
            {%- else -%}
              <span class="about-floating-stat__icon-placeholder" aria-hidden="true">★</span>
            {%- endif -%}
          </div>
          <span class="about-floating-stat__label">{{ block.settings.label }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "About Floating Stats",
  "tag": "section",
  "class": "section-about-floating-stats",
  "settings": [
    {
      "type": "header",
      "content": "Section info"
    },
    {
      "type": "paragraph",
      "content": "Floats over the bottom of the hero section. Add up to 6 stat cards. Icons are recommended at 100×100 (PNG with transparent background, vector preferred)."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Recommended: 100×100 PNG (transparent background), SVG preferred. Max 50KB."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Years Building Trikes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Floating Stats",
      "blocks": [
        { "type": "stat", "settings": { "label": "6+ Years Building Trikes" } },
        { "type": "stat", "settings": { "label": "9+ Models In Lineup" } },
        { "type": "stat", "settings": { "label": "85 mi Max Range" } },
        { "type": "stat", "settings": { "label": "2-Year Warranty" } }
      ]
    }
  ]
}
{% endschema %}
