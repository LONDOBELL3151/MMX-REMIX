<style>
	* {
		margin: 0;
		padding: 0;
	}

	.capacity {
		max-width: {{ section.settings.max_width }};
		margin: {{ section.settings.pc_margin_top }} auto {{ section.settings.pc_margin_bottom }};
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.capacity .img {
		width: 60%;
	}

	.capacity .img img {
		width: 100%;
		display: block;
	}

	.capacity .side {
		width: 35%;
	}

	.capacity .side .side-page {
		display: flex;
		align-items: center;
		margin: 10px 0;
	}

	.capacity .side .side-page .imgs {
		width: 80px;
		height: 80px;
	}

	.capacity .side .side-page .imgs img {
		width: 100%;
		display: block;
	}

	.capacity .side .side-page .side-page-text {}

	.capacity .side .side-page .side-page-text h2 {
		font-size: 36px;
		/* padding: 10px 0; */
		color: #000;
	}

	.capacity .side .side-page .side-page-text p {
		color: #5a5a5a;
		font-size: 20px;
	}

	@media screen and (max-width: 767px) {
		.capacity {
			display: block;
			margin: {{ section.settings.mb_margin_top }} auto {{ section.settings.mb_margin_bottom }};
		}

		.capacity .img {
			width: 100%;
		}

		.capacity .side {
			width: 100%;
			display: flex;
			flex-wrap: wrap;
		}

		.capacity .side .side-page {
			width: 50%;
			flex-shrink: 0;
		}
      .capacity .side .side-page .side-page-text {}

	.capacity .side .side-page .side-page-text h2 {
		font-size: 21px;
		/* padding: 10px 0; */
		color: #000;
	}

	.capacity .side .side-page .side-page-text p {
		color: #5a5a5a;
		font-size: 12px;
	}

	@media screen and (max-width: 767px) {
		.capacity {
			display: block;
			margin: 0px auto 0px;
		}
	}
</style>

<div class="capacity">
	<div class="img">
		{% if section.settings.main_image != blank %}
			<img src="{{ section.settings.main_image | img_url: '1000x' }}" alt="{{ section.settings.main_image.alt }}">
		{% else %}
			{{ 'image' | placeholder_svg_tag }}
		{% endif %}
	</div>

	<div class="side">
		{% for block in section.blocks %}
			<div class="side-page">
				<div class="imgs">
					{% if block.settings.icon != blank %}
						<img src="{{ block.settings.icon | img_url: 'master' }}" alt="{{ block.settings.icon.alt }}">
					{% else %}
						{{ 'image' | placeholder_svg_tag }}
					{% endif %}
				</div>
				<div class="side-page-text">
					{% if block.settings.main_title != blank %}
						<h2>{{ block.settings.main_title }}</h2>
					{% endif %}

					{% if block.settings.text != blank %}
						<p>{{ block.settings.text }}</p>
					{% endif %}
				</div>
			</div>
		{% endfor %}
		
