{% schema %}
{
	"name": "Graphic Mudule",
	"tag": "section",
	"class": "section",
	"max_blocks": 6,
	"settings": [
		{
			"id":"max_width",
			"type": "text",
			"default": "1400px",
			"label":"请设置模块最大宽度:"
		},
		{
			"id":"main_image",
			"type": "image_picker",
			"label":"请选择主图："
		},
		{
			"id":"pc_margin_top",
			"type": "text",
			"default": "0px",
			"label":"请设置模块在PC端的顶部边距:"
		},
		{
			"id":"pc_margin_bottom",
			"type": "text",
			"default": "0px",
			"label":"请设置模块在PC端的底部边距:"
		},
		{
			"id":"mb_margin_top",
			"type": "text",
			"default": "0px",
			"label":"请设置模块在移动端的顶部边距:"
		},
		{
			"id":"mb_margin_bottom",
			"type": "text",
			"default": "0px",
			"label":"请设置模块在移动端的底部边距:"
		}
	],
	"blocks":[
		{
			"name": "Item",
			"type":"slide",
			"settings": [
				{
					"id":"icon",
					"type": "image_picker",
					"label":"请选择配文图标："
				},
				{
					"id":"main_title",
					"type": "text",
					"default": "750 W",
					"label":"请输入主标题："
				},
				{
					"id":"text",
					"type": "textarea",
					"default": "Motor Torque",
					"label":"请输入配文："
				}
			]
		}	
	],
	"presets": [
		{
			"name": "Graphic Mudule",
			"blocks": [
				{
					"type": "slide"
				},
				{
					"type": "slide"
				},
				{
					"type": "slide"
				},
				{
					"type": "slide"
				}
			]
		}
	]
}
{% endschema %}