{%- liquid
  assign s = section.settings
-%}

<section class="section pdp-gallery" {{ section.shopify_attributes }}>
  <div class="container pdp__grid">
    <div class="pdp__media">
      {% render 'product-media' %}
    </div>

    <div class="pdp__info">
      <div class="pdp__category">{{ product.type | default: 'Electric Trike' }}</div>
      <h1 class="pdp__title">{{ product.title }}</h1>

      {%- comment -%}
        Shopify's native `rating` metafield is a JSON object
        {scale_min, scale_max, value} — {{ }} on it would serialize
        to a JSON string. Pull .value first so we get a plain number.
      {%- endcomment -%}
      {%- assign pdp_rating = 0 -%}
      {%- if product.metafields.reviews.rating and product.metafields.reviews.rating.value -%}
        {%- assign pdp_rating = product.metafields.reviews.rating.value | times: 1.0 -%}
      {%- endif -%}
      {%- assign pdp_review_count = product.metafields.reviews.rating_count | default: 0 -%}
      {%- if pdp_rating > 0 -%}
        <div class="pdp__rating">
          {% render 'stars', rating: pdp_rating %}
          <span class="pdp__rating-text">{{ pdp_rating }} ({{ pdp_review_count }} reviews)</span>
        </div>
      {%- else -%}
        <div class="pdp__rating pdp__rating--empty">
          <span class="pdp__rating-text">No reviews yet</span>
        </div>
      {%- endif -%}

      {% render 'price' %}

      {%- if s.show_stock -%}
        <div class="pdp__stock">
          {% render 'icon', icon: 'check', size: 14 %}
          <strong>In stock</strong> &mdash; {{ s.stock_count | default: 24 }} available
          &mdash; Ships within 2 business days
        </div>
      {%- endif -%}

      {%- liquid
        # If this product has a `custom.product_family` metaobject that lists
        # sibling color products, render the cross-product color picker and
        # skip the in-product Color variant below (it's already split across
        # products). Any non-Color option (Size, etc.) still renders.
        assign has_color_family = false
        if product.metafields.custom.product_family.value != blank
          if product.metafields.custom.product_family.value.members.value.size > 1
            assign has_color_family = true
          endif
        endif
      -%}

      {%- if has_color_family -%}
        {% render 'pdp-color-family' %}
      {%- endif -%}

      {%- if product.options.size > 0 -%}
        <form method="post" action="{{ routes.cart_add_url }}" id="pdp__form" enctype="multipart/form-data" class="pdp__form">
          <input type="hidden" name="id" data-product-id>
          {%- for option in product.options_with_values -%}
            {%- if has_color_family and option.name == 'Color' -%}
              {%- continue -%}
            {%- endif -%}
            <div class="pdp__option">
              <label class="pdp__option-label">
                {{ option.name }}:
                <strong data-selected-option="{{ forloop.index0 }}">{{ option.selected_value }}</strong>
              </label>
              {%- if option.name == 'Color' -%}
                <div class="pdp__swatches">
                  {%- for value in option.values -%}
                    {%- assign variant = nil -%}
                    {%- for v in product.variants -%}
                      {%- if v.option1 == value -%}
                        {%- assign variant = v -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- comment -%}
                      Swatch color resolution order:
                        1. variant.metafields.custom.color_hex  (per-variant override)
                        2. name-based map (common colors + MaxFoot brand colors)
                        3. neutral gray fallback
                      The name map uses | handleize so "Neptune Blue" -> "neptune-blue".
                      For brand-specific colors the merchant should set the
                      color_hex metafield on each variant — that wins regardless
                      of the name guess.
                    {%- endcomment -%}
                    {%- assign swatch_hex = blank -%}
                    {%- if variant and variant.metafields.custom.color_hex != blank -%}
                      {%- assign swatch_hex = variant.metafields.custom.color_hex -%}
                    {%- else -%}
                      {%- assign swatch_name = value | downcase | handleize -%}
                      {%- case swatch_name -%}
                        {%- when 'red' -%}{%- assign swatch_hex = '#d32f2f' -%}
                        {%- when 'crimson' -%}{%- assign swatch_hex = '#dc143c' -%}
                        {%- when 'orange' -%}{%- assign swatch_hex = '#ff6b1a' -%}
                        {%- when 'burning-orange' -%}{%- assign swatch_hex = '#ff5722' -%}
                        {%- when 'vibrant-orange' -%}{%- assign swatch_hex = '#ff6f00' -%}
                        {%- when 'yellow' -%}{%- assign swatch_hex = '#fbc02d' -%}
                        {%- when 'gold' -%}{%- assign swatch_hex = '#d4af37' -%}
                        {%- when 'green' -%}{%- assign swatch_hex = '#388e3c' -%}
                        {%- when 'lime' -%}{%- assign swatch_hex = '#9ccc65' -%}
                        {%- when 'pangea-green' -%}{%- assign swatch_hex = '#2e7d32' -%}
                        {%- when 'teal' -%}{%- assign swatch_hex = '#00897b' -%}
                        {%- when 'cyan' -%}{%- assign swatch_hex = '#00acc1' -%}
                        {%- when 'blue' -%}{%- assign swatch_hex = '#1976d2' -%}
                        {%- when 'navy' -%}{%- assign swatch_hex = '#0d2c54' -%}
                        {%- when 'neptune-blue' -%}{%- assign swatch_hex = '#1e3a5f' -%}
                        {%- when 'purple' -%}{%- assign swatch_hex = '#7b1fa2' -%}
                        {%- when 'pink' -%}{%- assign swatch_hex = '#d81b60' -%}
                        {%- when 'brown' -%}{%- assign swatch_hex = '#5d4037' -%}
                        {%- when 'beige' -%}{%- assign swatch_hex = '#d7c3a5' -%}
                        {%- when 'tan' -%}{%- assign swatch_hex = '#c9a87c' -%}
                        {%- when 'black' -%}{%- assign swatch_hex = '#1a1a1a' -%}
                        {%- when 'white' -%}{%- assign swatch_hex = '#ffffff' -%}
                        {%- when 'gray', 'grey' -%}{%- assign swatch_hex = '#6b6b6b' -%}
                        {%- when 'brooklyn-gray' -%}{%- assign swatch_hex = '#6b6b6b' -%}
                        {%- when 'silver' -%}{%- assign swatch_hex = '#c0c0c0' -%}
                      {%- endcase -%}
                    {%- endif -%}
                    {%- if swatch_hex == blank -%}{%- assign swatch_hex = '#cccccc' -%}{%- endif -%}
                    <label class="swatch" data-swatch="{{ value | handleize }}">
                      <input type="radio" name="options[{{ option.name | downcase }}]" value="{{ value }}" {% if option.selected_value == value %}checked{% endif %} data-variant-id="{{ variant.id | default: '' }}" data-option-index="{{ forloop.index0 }}">
                      <span class="swatch__color" style="background:{{ swatch_hex }}{% if swatch_hex == '#ffffff' %};border:1px solid #ccc{% endif %}"></span>
                      <span class="swatch__label">{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <select name="options[{{ option.name | downcase }}]" class="pdp__select" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              {%- endif -%}
            </div>
          {%- endfor -%}

          <div class="pdp__qty-row">
            <div class="pdp__qty">
              <button type="button" data-qty="dec" aria-label="Decrease">{% render 'icon', icon: 'minus' %}</button>
              <input type="number" name="quantity" value="1" min="1" data-qty-input>
              <button type="button" data-qty="inc" aria-label="Increase">{% render 'icon', icon: 'plus' %}</button>
            </div>
            <button type="submit" name="add" class="btn btn--primary pdp__cta"{% unless product.available %} disabled{% endunless %}>
              {%- if product.available -%}
                Add to Cart <span class="pdp__cta-price">&mdash; {{ product.price | money }}</span>
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>
          </div>
        </form>
      {%- else -%}
        {% form 'product', product, id: 'pdp__form' %}
          <div class="pdp__qty-row">
            <div class="pdp__qty">
              <button type="button" data-qty="dec">{% render 'icon', icon: 'minus' %}</button>
              <input type="number" name="quantity" value="1" min="1">
              <button type="button" data-qty="inc">{% render 'icon', icon: 'plus' }}</button>
            </div>
            <button type="submit" class="btn btn--primary pdp__cta">Add to Cart <span class="pdp__cta-price">&mdash; {{ product.price | money }}</span></button>
          </div>
        {% endform %}
      {%- endif -%}

      {%- if s.show_finance -%}
        <div class="pdp__finance">
          Or <strong>4 payments of {{ product.price | divided_by: 4 | money }}</strong>
          &mdash; <a href="{{ s.finance_link | default: '#' }}">{{ s.finance_label | default: 'Affirm financing' }}</a>
        </div>
      {%- endif -%}

      {%- if s.show_extras -%}
        <div class="pdp__extras">
          {%- for block in section.blocks -%}
            {%- if block.type == 'extra' -%}
              <div class="pdp__extra" {{ block.shopify_attributes }}>
                <span class="pdp__extra-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}{% render 'icon', icon: 'truck', size: 20 %}
                    {%- when 'shield' -%}{% render 'icon', icon: 'shield', size: 20 %}
                    {%- when 'calendar' -%}{% render 'icon', icon: 'calendar', size: 20 %}
                    {%- when 'phone' -%}{% render 'icon', icon: 'phone', size: 20 %}
                    {%- else -%}{% render 'icon', icon: 'check', size: 20 %}
                  {%- endcase -%}
                </span>
                <strong>{{ block.settings.title }}</strong>
                <span class="pdp__extra-sub">{{ block.settings.subtitle }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product main",
  "tag": "section",
  "class": "section-pdp-main",
  "settings": [
    { "type": "checkbox", "id": "show_stock", "label": "Show stock status", "default": true },
    { "type": "text", "id": "stock_count", "label": "Stock count" },
    { "type": "checkbox", "id": "show_finance", "label": "Show financing line", "default": true },
    { "type": "text", "id": "finance_label", "label": "Finance label", "default": "Affirm financing" },
    { "type": "url", "id": "finance_link", "label": "Finance link" },
    { "type": "checkbox", "id": "show_extras", "label": "Show extras (free shipping, etc.)", "default": true }
  ],
  "blocks": [
    {
      "type": "extra",
      "name": "Extra",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "phone", "label": "Phone" },
            { "value": "check", "label": "Check" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Ships within 2 business days" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "extra", "settings": { "icon": "truck", "title": "Free Shipping", "subtitle": "Ships within 2 business days" } },
      { "type": "extra", "settings": { "icon": "shield", "title": "2-Year Warranty", "subtitle": "Full bumper-to-bumper coverage" } },
      { "type": "extra", "settings": { "icon": "phone", "title": "US Support", "subtitle": "Reno, NV team · 1-866-MAXFOOT" } }
    ]
  }
}
{% endschema %}
