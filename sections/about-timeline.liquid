{%- liquid
  assign s = section.settings
-%}

<section class="about-timeline" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="section__head">
      <h2 class="section__title">{{ s.heading | default: 'Brand Evolution.' }}</h2>
      {%- if s.subheading != blank -%}
        <p class="section__sub">{{ s.subheading }}</p>
      {%- endif -%}
    </div>

    <ol class="about-timeline__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milestone' -%}
          {%- assign idx = forloop.index -%}
          {%- assign side = idx | modulo: 2 -%}
          {%- if side == 1 -%}
            {%- assign layout_mod = 'image-right' -%}
          {%- else -%}
            {%- assign layout_mod = 'image-left' -%}
          {%- endif -%}
          <li class="about-timeline__item about-timeline__item--{{ layout_mod }}" {{ block.shopify_attributes }}>
            <div class="about-timeline__copy">
              <div class="about-timeline__year">{{ block.settings.year }}</div>
              <h3 class="about-timeline__title">{{ block.settings.title }}</h3>
              <p class="about-timeline__text">{{ block.settings.text }}</p>
            </div>

            <div class="about-timeline__media">
              {%- if block.settings.media_video_url != blank -%}
                <video
                  src="{{ block.settings.media_video_url }}"
                  {% if block.settings.media_image != blank %}poster="{{ block.settings.media_image | image_url: width: 960 }}"{% endif %}
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"></video>
              {%- elsif block.settings.media_image != blank -%}
                <img
                  src="{{ block.settings.media_image | image_url: width: 960 }}"
                  srcset="{{ block.settings.media_image | image_url: width: 480 }} 480w, {{ block.settings.media_image | image_url: width: 768 }} 768w, {{ block.settings.media_image | image_url: width: 960 }} 960w"
                  sizes="(max-width: 990px) 100vw, 50vw"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy">
              {%- else -%}
                <div class="about-timeline__media-placeholder" aria-hidden="true">
                  <span class="about-timeline__media-year">{{ block.settings.year }}</span>
                </div>
              {%- endif -%}
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "About Timeline",
  "tag": "section",
  "class": "section-about-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (use <em> for yellow highlight)",
      "default": "Brand <em>Evolution.</em>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From a single model to a full lineup of U.S.-focused electric trikes, in six years."
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year (e.g. 2019, 2020-2021, 2025-Present)",
          "default": "2019"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "First Model Launch"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "We officially launched our brand and introduced our first two wheel drive electric bike. This marked the beginning of our journey in electric mobility and laid the foundation for our continued growth."
        },
        {
          "type": "header",
          "content": "Media (image or video)"
        },
        {
          "type": "image_picker",
          "id": "media_image",
          "label": "Image / video poster",
          "info": "Recommended: 800×800 (1:1) or 960×720 (4:3), JPG/PNG, <200KB."
        },
        {
          "type": "text",
          "id": "media_video_url",
          "label": "Video URL (mp4)",
          "info": "Recommended: 800×800 mp4, H.264, <4MB. Direct .mp4 link. Takes priority over image."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "year": "2019", "title": "First Model Launch", "text": "We officially launched our brand and introduced our first two wheel drive electric bike. This marked the beginning of our journey in electric mobility and laid the foundation for our continued growth." } },
        { "type": "milestone", "settings": { "year": "2020-2021", "title": "First Electric Tricycle", "text": "Recognizing growing demand for stability and everyday practicality, we launched our first electric tricycle for adults and expanded our product direction." } },
        { "type": "milestone", "settings": { "year": "2021-2023", "title": "Monocoque Model Expansion", "text": "As R&D capabilities grew, we launched our 20-inch and 24-inch fat tire monocoque electric trikes for adults, improving frame structure, stability, and ride quality." } },
        { "type": "milestone", "settings": { "year": "2023-2025", "title": "Two-Seater Tricycle", "text": "Engineered as a reliable electric tricycle for 2 adults, this model expands our lineup, making our trikes perfect for personal transportation and shared family rides." } },
        { "type": "milestone", "settings": { "year": "2025-Present", "title": "Electric Motorcycle Development", "text": "The next addition to our lineup, premium electric motorcycles for sale, is coming soon. Stay tuned." } }
      ]
    }
  ]
}
{% endschema %}
