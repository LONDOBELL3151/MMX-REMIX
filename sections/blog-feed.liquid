{%- liquid
  assign s = section.settings
  assign blog = blogs[s.blog] | default: blogs['news']
  assign posts_count = s.posts_count | default: 3
-%}

<section class="section section--soft section--blog-feed" {{ section.shopify_attributes }}>
  <div class="container">

    <header class="section__head section__head--split">
      <div class="section__head-copy">
        {%- if s.heading != blank -%}
          <h2 class="section__title">{{ s.heading }}</h2>
        {%- endif -%}
        {%- if s.subheading != blank -%}
          <p class="section__sub">{{ s.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if s.see_all_url != blank -%}
        <a href="{{ s.see_all_url }}" class="section__hashlink">
          {% render 'icon', name: 'arrow-down' %}
          {{ s.see_all_text | default: 'See all articles' }}
        </a>
      {%- endif -%}
    </header>

    {%- if blog and blog.articles.size > 0 -%}
      <div class="blog-grid">
        {%- for article in blog.articles limit: posts_count -%}
          {% render 'post-card', post: article %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="blog-empty">No articles yet. Add some in <a href="/admin/blogs">Admin &gt; Content &gt; Blogs</a>.</p>
    {%- endif -%}

    {%- if s.cta_button_url != blank -%}
      <div class="blog-cta">
        <div>
          {%- if s.cta_title != blank -%}
            <p class="blog-cta__title">{{ s.cta_title }}</p>
          {%- endif -%}
          {%- if s.cta_sub != blank -%}
            <p class="blog-cta__sub">{{ s.cta_sub }}</p>
          {%- endif -%}
        </div>
        <a href="{{ s.cta_button_url }}" class="blog-cta__btn">
          {{ s.cta_button_text | default: 'Visit the journal' }}
          {% render 'icon', name: 'arrow-right' %}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Blog feed (homepage)",
  "tag": "section",
  "class": "section-blog-feed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Read the <em>journal.</em>", "info": "Wrap a word in <em>...</em> for the yellow accent." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Buying guides, maintenance tips, and family adventures - written by riders who actually own a MaxFoot." },
    { "type": "header", "content": "See-all link (top right)" },
    { "type": "url", "id": "see_all_url", "label": "See-all URL", "info": "e.g. /blogs/news" },
    { "type": "text", "id": "see_all_text", "label": "See-all label", "default": "See all articles" },
    { "type": "header", "content": "Posts" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "posts_count", "label": "Posts to show", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "header", "content": "Bottom CTA strip" },
    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Binge the <em>whole journal.</em>", "info": "Wrap a word in <em>...</em> for the yellow accent." },
    { "type": "text", "id": "cta_sub", "label": "CTA subtext", "default": "60+ articles on buying, riding, and maintaining your MaxFoot. Updated weekly." },
    { "type": "text", "id": "cta_button_text", "label": "CTA button text", "default": "Visit the journal" },
    { "type": "url", "id": "cta_button_url", "label": "CTA button URL", "info": "e.g. /blogs/news" }
  ],
  "presets": [
    { "name": "Blog feed (homepage)" }
  ]
}
{% endschema %}
