{%- liquid
  assign s = section.settings
-%}

<section class="stats" aria-label="Stats" {{ section.shopify_attributes }}>
  <div class="container">
    {%- if s.heading != blank or s.subheading != blank -%}
    <div class="section__head">
      {%- if s.heading != blank -%}
        <h2 class="section__title">{{ s.heading }}</h2>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <p class="section__sub">{{ s.subheading }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    <div class="stats__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="stats__item" {{ block.shopify_attributes }}>
            {%- assign num = block.settings.number -%}
            {%- assign em = block.settings.unit -%}
            <div class="stats__num">
              {%- if em != blank -%}
                {{ num }}<em>{{ em }}</em>
              {%- else -%}
                {{ num }}
              {%- endif -%}
            </div>
            <div class="stats__label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Stats",
  "tag": "section",
  "class": "section-about-stats",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "6"
        },
        {
          "type": "text",
          "id": "unit",
          "label": "Unit (yellow, e.g. +, mi, yr)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Years Building Trikes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Stats",
      "blocks": [
        { "type": "stat", "settings": { "number": "6", "unit": "+", "label": "Years Building Trikes" } },
        { "type": "stat", "settings": { "number": "9", "unit": "+", "label": "Models In Lineup" } },
        { "type": "stat", "settings": { "number": "85", "unit": "mi", "label": "Max Battery Range" } },
        { "type": "stat", "settings": { "number": "2", "unit": "yr", "label": "Full Warranty" } }
      ]
    }
  ]
}
{% endschema %}
