{%- liquid
  assign s = section.settings
  assign year = 'now' | date: '%Y'
-%}

<footer class="footer" role="contentinfo" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="logo logo--img" aria-label="{{ shop.name | escape }} home">
          {%- if s.footer_logo != blank -%}
            <img src="{{ s.footer_logo | image_url: width: 600 }}" alt="{{ s.footer_logo.alt | default: shop.name | escape }}" loading="lazy" width="220" height="44">
          {%- elsif settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 600 }}" alt="{{ settings.logo.alt | default: shop.name | escape }}" loading="lazy" width="220" height="44">
          {%- else -%}
            <span class="logo__text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        {%- if s.tagline != blank -%}
          <p class="footer__about">{{ s.tagline }}</p>
        {%- endif -%}

        {%- if s.show_social -%}
          <div class="footer__social">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', icon: 'facebook' %}</a>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="Twitter">{% render 'icon', icon: 'twitter' %}</a>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', icon: 'tiktok' %}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' or block.type == 'link_list' -%}
          {%- assign menu = block.settings.menu -%}
          {%- if menu != blank or block.settings.heading != blank -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              {%- if menu != blank -%}
                <ul>
                  {%- for link in menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- elsif block.type == 'newsletter' -%}
          <div class="footer__col footer__col--newsletter" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading | default: 'Stay in the loop' }}</h4>
            <p>{{ block.settings.subtext | default: '$50 off your first order + exclusive deals.' }}</p>
            {% form 'customer', id: 'footer-newsletter', class: 'newsletter__form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="email" name="contact[email]" placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}" required>
              <button type="submit" class="btn btn--primary">
                {{ block.settings.button_label | default: 'Subscribe' }}
              </button>
            {% endform %}
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <div class="footer__text">{{ block.settings.text }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div>© {{ year }} {{ shop.name }}. {{ s.copyright_text }}</div>
      {%- if s.show_payment_icons -%}
        <div class="footer__payments">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .footer .logo--img img { height: 44px; width: auto; filter: invert(0) brightness(0) saturate(100%) invert(1); }
  @media (max-width: 560px) {
    .footer .logo--img img { height: 32px; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo (leave blank to use theme logo)"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Premium folding e-bikes and electric tricycles built for American families. Ships from our US warehouse with a 2-year warranty and 14-day free trial."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu column (legacy)",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter signup",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the loop" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "$50 off your first order + exclusive deals." },
        { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Policies" } },
      { "type": "menu", "settings": { "heading": "Support" } },
      { "type": "menu", "settings": { "heading": "Company" } },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
