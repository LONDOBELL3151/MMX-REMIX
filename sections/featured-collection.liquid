{%- liquid
  assign s = section.settings
-%}

<section class="section section--lineup" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="section__head">
      <h2 class="section__title">{{ s.heading | default: 'The lineup' }}</h2>
      {%- if s.subheading != blank -%}
        <p class="section__sub">{{ s.subheading }}</p>
      {%- endif -%}
    </div>

    {%- assign product_blocks_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'product' and block.settings.product != blank -%}
        {%- assign product_blocks_count = product_blocks_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if product_blocks_count > 0 -%}
      <div class="products products--grid products--{{ s.columns | default: 3 }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            {% render 'product-card', product: block.settings.product, show_specs: true %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="products-empty">No products added yet. Open the theme editor and add products to this section.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The lineup"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "soft", "label": "Soft" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 25,
  "presets": [
    {
      "name": "Featured collection",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
