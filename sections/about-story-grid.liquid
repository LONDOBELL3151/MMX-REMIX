{%- liquid
  assign s = section.settings
  assign layout = s.layout | default: 'image_left'
  assign media_style = s.media_style | default: 'year_block'
-%}

<section class="story about-story-grid{% if s.background == 'soft' %} story--soft{% endif %}" {{ section.shopify_attributes }}>
  <div class="container story-grid{% if layout == 'image_right' %} story-grid--reverse{% endif %}">
    <div>
      {%- if s.eyebrow != blank -%}
        <span class="story-eyebrow">{{ s.eyebrow }}</span>
      {%- endif -%}
      <h2 class="story-grid__title">{{ s.title }}</h2>
      {%- if s.lead_text != blank -%}
        <p class="story-grid__lead">{{ s.lead_text }}</p>
      {%- endif -%}
      {%- if s.body_text != blank -%}
        {{ s.body_text }}
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
      <ul class="story-grid__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'list_item' -%}
            <li {{ block.shopify_attributes }}><span>{{ block.settings.text }}</span></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      {%- endif -%}
    </div>

    <div class="story-grid__media about-story-grid__media about-story-grid__media--{{ media_style }}">
      {%- if s.media_video_url != blank -%}
        <video
          class="about-story-grid__media-video"
          src="{{ s.media_video_url }}"
          {% if s.media_image != blank %}poster="{{ s.media_image | image_url: width: 1280 }}"{% endif %}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"></video>
        {%- if s.media_caption != blank -%}
          <span class="story-grid__media-tag">{{ s.media_caption }}</span>
        {%- endif -%}
      {%- elsif s.media_image != blank -%}
        <img
          class="about-story-grid__media-img"
          src="{{ s.media_image | image_url: width: 1280 }}"
          srcset="{{ s.media_image | image_url: width: 640 }} 640w, {{ s.media_image | image_url: width: 960 }} 960w, {{ s.media_image | image_url: width: 1280 }} 1280w"
          sizes="(max-width: 990px) 100vw, 50vw"
          alt="{{ s.title | escape }}"
          loading="lazy">
        {%- if s.media_caption != blank -%}
          <span class="story-grid__media-tag">{{ s.media_caption }}</span>
        {%- endif -%}
      {%- elsif media_style == 'year_block' -%}
        <div class="about-story-grid__placeholder about-story-grid__placeholder--year">
          <span class="about-story-grid__placeholder-year">{{ s.media_year | default: '2019' }}</span>
          <span class="story-grid__media-tag">{{ s.media_tag | default: 'Founded In The U.S.' }}</span>
        </div>
      {%- elsif media_style == 'ul_badge' -%}
        <div class="about-story-grid__placeholder about-story-grid__placeholder--ul">
          <div class="about-story-grid__placeholder-ul-mark">UL</div>
          <div class="about-story-grid__placeholder-ul-text">CERTIFIED</div>
          <div class="about-story-grid__placeholder-ul-sub">{{ s.media_subtitle | default: 'Samsung 48V 20Ah Battery' }}</div>
          <span class="story-grid__media-tag">{{ s.media_tag | default: 'Rigorously Tested' }}</span>
        </div>
      {%- elsif media_style == 'category_blocks' -%}
        <div class="about-story-grid__placeholder about-story-grid__placeholder--cats">
          {%- assign cats = s.media_categories | default: 'Seniors,Families,Commuters,Leisure' | split: ',' -%}
          {%- for cat in cats -%}
            <div class="about-story-grid__placeholder-cat">{{ cat | strip }}</div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Story Grid",
  "tag": "section",
  "class": "section-about-story-grid",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Section background",
      "options": [
        { "value": "default", "label": "Default (white)" },
        { "value": "soft", "label": "Soft (light gray)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_left", "label": "Media left, text right" },
        { "value": "image_right", "label": "Text left, media right" }
      ],
      "default": "image_left"
    },
    {
      "type": "header",
      "content": "Media (image or video)"
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Media image / video poster",
      "info": "Recommended: 1280×960 (4:3), JPG/PNG, <300KB. Used as video poster if video is set, otherwise as full media."
    },
    {
      "type": "text",
      "id": "media_video_url",
      "label": "Media video URL (mp4)",
      "info": "Recommended: 1280×960 mp4, H.264, <6MB. Direct .mp4 link. Takes priority over image. Leave blank to use image."
    },
    {
      "type": "text",
      "id": "media_caption",
      "label": "Yellow tag caption (bottom-left of media)",
      "info": "Optional. Shown over image or video, e.g. 'Rigorously Tested'."
    },
    {
      "type": "select",
      "id": "media_style",
      "label": "Placeholder style (when no media is set)",
      "options": [
        { "value": "year_block", "label": "Year block (yellow gradient + big year)" },
        { "value": "category_blocks", "label": "Category blocks (2x2 grid)" },
        { "value": "ul_badge", "label": "UL badge (black with yellow text)" }
      ],
      "default": "year_block"
    },
    {
      "type": "header",
      "content": "Text side"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Who Is MaxFoot?"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title (use <em> for yellow highlight)",
      "default": "We stepped in to balance <em>affordability, safety, and everyday practicality.</em>"
    },
    {
      "type": "richtext",
      "id": "lead_text",
      "label": "Lead paragraph"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Placeholder text (when no media uploaded)"
    },
    {
      "type": "text",
      "id": "media_year",
      "label": "Year block: big year text",
      "default": "2019",
      "info": "Only used when Media style = Year block"
    },
    {
      "type": "text",
      "id": "media_tag",
      "label": "Yellow tag label",
      "default": "Founded In The U.S."
    },
    {
      "type": "text",
      "id": "media_subtitle",
      "label": "UL badge: small subtitle",
      "default": "Samsung 48V 20Ah Battery",
      "info": "Only used when Media style = UL badge"
    },
    {
      "type": "text",
      "id": "media_categories",
      "label": "Category blocks: 4 names (comma-separated)",
      "default": "Seniors,Families,Commuters,Leisure",
      "info": "Only used when Media style = Category blocks"
    }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Stability & balance for seniors"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Story Grid"
    }
  ]
}
{% endschema %}
