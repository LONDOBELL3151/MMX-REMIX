{{ 'swiper-bundle.css' | asset_url | stylesheet_tag }}

{{ 'home-banner.css' | asset_url | stylesheet_tag }}
<div class="homepage">
  <div class="swiper bannerSwiper bannerSwiper-{{- section.id -}}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.banner-href }}">
            <picture>
              {% if block.settings.phone_Image %}
                <source media="(max-width:750px)" srcset="{{ block.settings.phone_Image | image_url: width: 750 }}">
              {% else %}
                <source media="(max-width:750px)" srcset="{{ '404_MB.png' | asset_img_url: '750x1000' }}">
              {% endif %}

              {%- if block.settings.pc_Image -%}
                <img 
                  src="{{ block.settings.pc_Image | image_url: width: 1920 }}" 
                  alt="{{ block.settings.alt_text | default: 'Maxfoot electric bike banner' }}"
                  {% if forloop.first %}
                    loading="eager"
                    fetchpriority="high"
                  {% else %}
                    loading="lazy"
                  {% endif %}
                >
              {%- else -%}
                <img src="{{ '404_PC.png' | asset_img_url: '1920x820' }}" alt="" loading="lazy">
              {%- endif -%}
            </picture>
          </a>
        </div>
      {% endfor %}
    </div>
    <div class="swiper-pagination"></div>
  </div>

</div>
{{ 'swiper-bundle.js' | asset_url | script_tag }}

{% schema %}
  {
    "name": "Home-Slide Show",
    "settings": [],
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "max_blocks": 5,
    "blocks": [
      {
        "name": "Image Item",
        "type": "pc_a",
        "settings": [
          {
            "type": "image_picker",
            "id": "pc_Image",
            "label": "pc_Image"
          }, {
            "type": "image_picker",
            "id": "phone_Image",
            "label": "phone_Image"
          }, {
            "type": "text",
            "id": "banner-href",
            "label": "banner-href"
          },{
        "type": "text",
        "id": "alt_text",
        "label": "Image alt text",
        "default": "MaxFoot electric bike banner"
      }
          ]
      }
    ],
    "presets": [
      {
        "name": "Home-Slide Show",
        "blocks": [
          {
            "type": "pc_a"
          }, {
            "type": "pc_a"
          }, {
            "type": "pc_a"
          }
        ]
      }
    ]
  }
{% endschema %}
<script>
  var swiper = new Swiper(".bannerSwiper-                 {{- section.id -}}", {
    loop: true,
    effect: 'fade',
    autoplay: {
      delay: 4000,
      disableOnInteraction: false
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true
    }
  });
</script>