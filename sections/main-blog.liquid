{%- liquid
  assign s = section.settings
  assign blog = blogs[s.blog] | default: blogs['news']
-%}

<section class="main-blog section" {{ section.shopify_attributes }}>
  <div class="container">
    {%- if blog.articles.size == 0 -%}
      <div class="blog-empty">
        <h2>No posts yet.</h2>
        <p>Check back soon, or follow us on <a href="{{ settings.social_instagram_link }}">Instagram</a> for updates.</p>
      </div>
    {%- else -%}
      {%- assign featured = blog.articles.first -%}
      {%- paginate blog.articles by 6 -%}
        <div class="blog-grid">

          <article class="post-card post-card--featured" data-post-id="{{ featured.id }}">
            <a href="{{ featured.url }}" class="post-card__link">
              <div class="post-card__media"{% if featured.image %} style="background-image:url({{ featured.image | image_url: width: 1200 }})"{% endif %}>
                <span class="post-card__cat">{{ featured.tags | first | default: 'Article' }}</span>
              </div>
            </a>
            <div class="post-card__body">
              <div class="post-card__meta">
                <span>{{ featured.tags | first | default: 'Article' }}</span>
                <span class="post-card__dot"></span>
                <span>{{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 }} min read</span>
                <span class="post-card__dot"></span>
                <span>{{ featured.published_at | date: '%b %d, %Y' }}</span>
              </div>
              <h2 class="post-card__title"><a href="{{ featured.url }}">{{ featured.title }}</a></h2>
              <p class="post-card__excerpt">
                {%- if featured.excerpt != blank -%}
                  {{ featured.excerpt | strip_html | truncatewords: 80 }}
                {%- else -%}
                  {%- assign _ct = featured.content | strip_html -%}
                  {%- assign _tt = featured.title | strip_html -%}
                  {%- if _ct contains _tt -%}{{ _ct | remove: _tt | strip | truncatewords: 80 }}{%- else -%}{{ _ct | truncatewords: 80 }}{%- endif -%}
                {%- endif -%}
              </p>
              <a href="{{ featured.url }}" class="post-card__cta">Read the guide {% render 'icon', icon: 'arrow-right' %}</a>
            </div>
          </article>

          {%- for article in blog.articles offset: 1 -%}
            {% render 'post-card', post: article %}
          {%- endfor -%}

        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination__prev">
                {% render 'icon', icon: 'chevron-left' %}
              </a>
            {%- else -%}
              <span class="pagination__prev is-disabled">
                {% render 'icon', icon: 'chevron-left' %}
              </span>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__page">{{ part.title }}</a>
              {%- else -%}
                <span class="pagination__page{% if part.title == paginate.current_page %} is-current{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination__next">
                {% render 'icon', icon: 'chevron-right' %}
              </a>
            {%- else -%}
              <span class="pagination__next is-disabled">
                {% render 'icon', icon: 'chevron-right' %}
              </span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "section-blog-posts",
  "settings": [
    { "type": "blog", "id": "blog", "label": "Blog", "info": "If empty, falls back to the current blog on /blogs/<handle>." }
  ],
  "presets": [
    { "name": "Blog posts" }
  ]
}
{% endschema %}
