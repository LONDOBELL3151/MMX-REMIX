{%- liquid
  assign s = section.settings
-%}

<section class="about-floating-story" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="about-floating-story__card">
      <div class="about-floating-story__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="about-floating-story__stat" {{ block.shopify_attributes }}>
              {%- if block.settings.number != blank -%}
                <div class="about-floating-story__stat-num">{{ block.settings.number }}</div>
              {%- endif -%}
              {%- if block.settings.icon != blank -%}
                <div class="about-floating-story__stat-icon">
                  <img src="{{ block.settings.icon | image_url: width: 240 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="120" height="120">
                </div>
              {%- endif -%}
              <div class="about-floating-story__stat-label">{{ block.settings.label }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if s.story_title != blank or s.story_body != blank or s.story_image != blank or s.story_video_url != blank or s.story_button_label != blank -%}
      <div class="about-floating-story__divider" aria-hidden="true"></div>

      <div class="about-floating-story__content">
        <div class="about-floating-story__copy">
          {%- if s.story_eyebrow != blank -%}
            <span class="about-floating-story__eyebrow">{{ s.story_eyebrow }}</span>
          {%- endif -%}

          {%- if s.story_title != blank -%}
            <h2 class="about-floating-story__title">{{ s.story_title }}</h2>
          {%- endif -%}

          {%- if s.story_body != blank -%}
            <div class="about-floating-story__body">{{ s.story_body }}</div>
          {%- endif -%}

          {%- if s.story_button_label != blank and s.story_button_link != blank -%}
            <a href="{{ s.story_button_link }}" class="about-floating-story__btn" {% if s.story_button_external %}target="_blank" rel="noopener noreferrer"{% endif %}>
              {{ s.story_button_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if s.story_video_url != blank or s.story_image != blank -%}
        <div class="about-floating-story__media">
          {%- if s.story_video_url != blank -%}
            <video
              src="{{ s.story_video_url }}"
              {% if s.story_image != blank %}poster="{{ s.story_image | image_url: width: 1280 }}"{% endif %}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"></video>
          {%- elsif s.story_image != blank -%}
            <img
              src="{{ s.story_image | image_url: width: 1280 }}"
              srcset="{{ s.story_image | image_url: width: 640 }} 640w, {{ s.story_image | image_url: width: 960 }} 960w, {{ s.story_image | image_url: width: 1280 }} 1280w"
              sizes="(max-width: 990px) 100vw, 50vw"
              alt="{{ s.story_title | escape }}"
              loading="lazy">
          {%- endif -%}
        </div>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Floating Story",
  "tag": "section",
  "class": "section-about-floating-story",
  "settings": [
    {
      "type": "header",
      "content": "Top: stat cards (4 default)"
    },
    {
      "type": "paragraph",
      "content": "Icons are recommended at 100×100 (PNG with transparent background, vector preferred)."
    },
    {
      "type": "header",
      "content": "Bottom: story content"
    },
    {
      "type": "text",
      "id": "story_eyebrow",
      "label": "Story eyebrow",
      "default": "Our Story"
    },
    {
      "type": "inline_richtext",
      "id": "story_title",
      "label": "Story title (use <em> for highlight)",
      "default": "Designed for <em>real riders.</em>"
    },
    {
      "type": "richtext",
      "id": "story_body",
      "label": "Story body",
      "default": "<p>MaxFoot is changing the face of electric mobility. We build dependable, affordable trikes that fit the way Americans actually ride, so you can keep going without compromise.</p>"
    },
    {
      "type": "header",
      "content": "Media (image OR video)"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story image / video poster",
      "info": "Recommended: 1280×960 (4:3), JPG/PNG, <300KB."
    },
    {
      "type": "text",
      "id": "story_video_url",
      "label": "Story video URL (mp4)",
      "info": "Recommended: 1280×960 mp4, H.264, <6MB. Direct .mp4 link."
    },
    {
      "type": "header",
      "content": "Optional button"
    },
    {
      "type": "text",
      "id": "story_button_label",
      "label": "Button label",
      "default": "See Our Trikes"
    },
    {
      "type": "url",
      "id": "story_button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "story_button_external",
      "label": "Open link in new tab",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Big number (e.g. 700k, 6+, 85mi, A+)",
          "info": "Big outlined number. Leave blank to hide. Renders at ~64px."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (small, next to number)",
          "info": "Recommended: 120×120 PNG (transparent background), SVG preferred. Max 60KB."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (small, below)",
          "default": "Years Building Trikes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Floating Story",
      "blocks": [
        { "type": "stat", "settings": { "number": "6+", "label": "Years Building Trikes" } },
        { "type": "stat", "settings": { "number": "9+", "label": "Models In Lineup" } },
        { "type": "stat", "settings": { "number": "85mi", "label": "Max Battery Range" } },
        { "type": "stat", "settings": { "number": "2 yr", "label": "Full Warranty" } }
      ]
    }
  ]
}
{% endschema %}
