;\n        }\n\n        .a {\n            left: 3%;\n        }\n\n        .b,\n        .c,\n        .d {\n            left: 5%;\n        }\n\n        .electricEngine_R_bikeA,\n        .electricEngine_R_bg {\n            display: none;\n        }\n\n        .electricEngine_R_bikePhone,\n        .electricEngine_R_bgPhone {\n            display: block;\n        }\n\n        .electricEngine_R_bikePhone>div {\n            position: absolute;\n            top: 0;\n        }\n\n        .electricEngine_R_bikePhone img {\n            max-width: 450px;\n            width: 100%;\n        }\n\n        .aPhone {\n            right: 19%;\n            z-index: 4;\n        }\n\n        .bPhone {\n            right: 17%;\n            z-index: 3;\n        }\n\n        .cPhone {\n            right: 17%;\n            z-index: 2;\n        }\n\n        .dPhone {\n            right: 17%;\n        }\n    }\n\n    @media only screen and (max-width: 750px) {\n        .electricEngine_R_bikePhone {\n            zoom: .90;\n        }\n    }\n\n    @media only screen and (max-width: 700px) {\n        .electricEngine_R_bikePhone {\n            zoom: .85;\n        }\n    }\n\n    @media only screen and (max-width: 650px) {\n        .electricEngine_R_bikePhone {\n            zoom: .80;\n        }\n    }\n\n    @media only screen and (max-width: 600px) {\n        .electricEngine_R_bikePhone {\n            zoom: .75;\n        }\n    }\n\n    @media only screen and (max-width: 550px) {\n        .electricEngine_R_bikePhone {\n            zoom: .70;\n        }\n\n        .electricEngine_L_title {\n            font-size: 20px;\n        }\n\n        .electricEngine_L_word {\n            font-size: 12px;\n            padding-top: 10px;\n            line-height: 20px;\n        }\n\n        .electricEngine_L_tip_box h6 {\n            font-size: 15px;\n        }\n\n        .electricEngine_L_tip_box p {\n            font-size: 12px;\n            margin-top: 5px;\n        }\n    }\n\n    @media only screen and (max-width: 500px) {\n        .electricEngine_R_bikePhone {\n            zoom: .65;\n        }\n    }\n\n    @media only screen and (max-width: 450px) {\n        .electricEngine_R_bikePhone {\n            zoom: .60;\n        }\n    }\n\n    @media only screen and (max-width: 400px) {\n        .electricEngine_R_bikePhone {\n            zoom: .55;\n        }\n    }\n\n    @media only screen and (max-width: 350px) {\n        .electricEngine_R_bikePhone {\n            zoom: .50;\n        }\n    }\n\n    @media only screen and (max-width: 330px) {\n        .electricEngine_R_bikePhone {\n            zoom: .45;\n        }\n    }\n</style>\n\n<div class=\"electricEngine\">\n    <div class=\"electricEngine_R_bg\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/bb5.jpg?v=1682146025\" alt=\"\">\n    </div>\n    <div class=\"electricEngine_R_bgPhone\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/bb7.jpg?v=1682146025\" alt=\"\">\n    </div>\n    <div class=\"electricEngine_R_bikeA\">\n        <div class=\"a\"><img src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700MF.webp?v=1703732143\"\n                alt=\"\"></div>\n        <div class=\"b\"><img class=\"bb\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700_a1.gif?v=1682404760\" alt=\"\"></div>\n        <div class=\"c\"><img class=\"cc\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700_b2.gif?v=1682578312\" alt=\"\"></div>\n        <div class=\"d\"><img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/700.png?v=1682146092\"\n                alt=\"\"></div>\n    </div>\n    <div class=\"electricEngine_R_bikePhone\">\n        <div class=\"aPhone\"><img\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500MF.webp?v=1703732177\" alt=\"\"></div>\n        <div class=\"bPhone\"><img class=\"bbPhone\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500_a1.gif?v=1682578976\" alt=\"\"></div>\n        <div class=\"cPhone\"><img class=\"ccPhone\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500_b1.gif?v=1682578976\" alt=\"\"></div>\n        <div class=\"dPhone\"><img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/500.png?v=1682146089\"\n                alt=\"\"></div>\n    </div>\n    <div class=\"electricEngine_L\">\n        <h3 class=\"electricEngine_L_title\">\n            MAXFOOT 750W<br> Rear Drive Motor\n        </h3>\n        <p class=\"electricEngine_L_word\">The MAXFOOT powerful motor provides the MF-33 with a rated power of 750W (peak power 1100W) and a powerful torque of 85N.m. \n            In the new version in 2024, the position of the MF-33's motor has been changed to the rear wheel position. \n            This means that the entire vehicle is driven by the two rear wheels, and the driving mode is changed from the original <b>\"pull\"</b> to <b>\"push\"</b>. When riding on some special terrain, the front wheel will no longer slip. \n            The MAXFOOT motor will work with the two rear wheels to easily push you forward. Free from terrain anxiety, your rides will be easier and more enjoyable.</p>\n        <div class=\"electricEngine_L_tip\">\n            <div class=\"electricEngine_L_tip_box\">\n                <h6>750W</h6>\n                <p>Motor Power</p>\n            </div>\n            <div class=\"electricEngine_L_tip_box\">\n                <h6>85N.m</h6>\n                <p>Motor Torque</p>\n            </div>\n        </div>\n    </div>\n</div>\n\n<script src=\"{{ 'gsap.js' | asset_url }}\"></script>\n<script src=\"{{ 'scrollTrigger.js' | asset_url }}\"></script>\n<script>\n    var timerImg, timeOneImg, timeTwoImg;\n    function gsapFun(num1, num2) {\n        gsap.registerPlugin(ScrollTrigger);\n        gsap.timeline({\n            scrollTrigger: {\n                trigger: \".electricEngine\",\n                start: \"top center\",\n                end: \"top 10px\",\n                scrub: true\n            }\n        })\n            .to('.electricEngine_R_bg', { x: 100, opacity: 0.05 }, 0)\n            .to('.a', { x: num1 }, 0)\n            .to('.b', { x: num2, }, 0)\n    }\n\n    function gsapFunPhone(num1, num2) {\n        gsap.registerPlugin(ScrollTrigger);\n        gsap.timeline({\n            scrollTrigger: {\n                trigger: \".electricEngine\",\n                start: \"top center\",\n                end: \"+=40%\",\n                scrub: true\n            }\n        })\n            .to('.electricEngine_R_bgPhone', { x: 50, opacity: 0.05 }, 0)\n            .to('.aPhone', { x: num1 }, 0)\n            .to('.bPhone', { x: num2, }, 0)\n    }\n\n\n    window.onload = function () {\n        gsapFun(-250, -20)\n        gsapFunPhone(-160, -20)\n    }\n\n    const iframeDom = document.querySelector('.electricEngine_R_bikeA')\n    const iframeDomPhone = document.querySelector('.electricEngine_R_bikePhone')\n    function aa(width, zoom, widthPhone, zoomPhone) {\n        if (window.innerWidth < width) {\n            iframeDom.style.zoom = window.innerWidth * zoom / width\n        } else {\n            iframeDom.style.zoom = zoom\n        }\n        if (window.innerWidth < widthPhone) {\n            iframeDomPhone.style.zoom = window.innerWidth * zoomPhone / widthPhone\n        } else {\n            iframeDomPhone.style.zoom = zoom\n        }\n    }\n    aa(1920, 1.02, 800, 1)\n    window.onresize = function () {\n        aa(1920, 1.02, 800, 1)\n    }\n</script>",
