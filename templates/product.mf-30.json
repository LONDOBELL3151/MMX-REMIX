            "bicycleTabs_contentDesc": "The electric trike for adults features a thick padded saddle with a unique design of backrest of the seat. It can improve your riding comfort and keep your riding comfortable at rough torgraphy."
          }
        },
        "0193ca49-e183-4cce-9696-91bc27acdf3f": {
          "type": "bicycleTabsBox",
          "settings": {
            "bicycleTabs_tabTitle": "SAMSUNG Lithium Battery",
            "bicycleTabs_contentImg": "shopify://shop_images/2_271242aa-da66-4d5f-8b52-085bfdc818eb.png",
            "bicycleTabs_contentHeader": "SAMSUNG Lithium Battery",
            "bicycleTabs_contentDesc": "The MF-30 fat tire electric trike provides a SAMSUNG 48V 20Ah high capacity battery, it can support MF-30 travel around 85+ miles on a single charge ( with PAS 1 )."
          }
        },
        "002bba25-ee92-4c6c-954f-331c03dca335": {
          "type": "bicycleTabsBox",
          "settings": {
            "bicycleTabs_tabTitle": "Dual Disc Brake",
            "bicycleTabs_contentImg": "shopify://shop_images/shuangdie_230f1325-98de-40ef-8c9f-1aaddbf1b64a.png",
            "bicycleTabs_contentHeader": "Dual Disc Brake",
            "bicycleTabs_contentDesc": "The fat tire electric trike are equipped with 180mm dual disc brakes for all wheels, which prevents rollover effectively. When you brake, the brake disc can be sensitively held tightly according to your needs."
          }
        },
        "8c9f4160-296f-45f1-9eed-c45e15a8b09f": {
          "type": "bicycleTabsBox",
          "settings": {
            "bicycleTabs_tabTitle": "Waterproof Rear Basket Bag",
