.progressBar_iconBar{\n        font-size: 17px;\n    }\n    .progressBar_iconTitle {\n        font-size: 20px;\n    }\n    .progressBar_icon img {\n        max-width: 30px;\n    }\n    .progressBar_iconBar .num img {\n        max-width: 15px;\n    }\n    .progressBar_iconBar .barBg {\n        line-height: 0.8;\n    }\n    .progressBar_iconBar .barBg {\n        width: 80%;\n    }\n\n}\n    </style>\n    <div class=\"progressBar\">\n        <div class=\"progressBar_msgContent\">\n            <div class=\"progressBar_msg\">\n                <figure>\n                    <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/progressBar_msg1.jpg?v=1708671100\" alt=\"\" >\n                    <figcaption>Rear Drive Motor</figcaption>\n                </figure>\n            </div>\n            <div class=\"progressBar_msg\">\n                <figure>\n                    <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/progressBar_msg2.jpg?v=1708671099\" alt=\"\" >\n                    <figcaption>Front Hub Motor</figcaption>\n                </figure>\n            </div>\n        </div>\n        <div class=\"progressBar_iconContent\">\n            <div class=\"progressBar_icon progressBar_icon1\">\n                <figure class=\"progressBar_iconTitle\">\n                    <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/progressBar_icon1.png?v=1708671099\" alt=\"\" >\n                    <figcaption>Speeded-Up</figcaption>\n                </figure>\n                <div class=\"progressBar_iconBar\">\n                    <p>Rear Drive Motor</p>\n                    <div class=\"bar_num\">\n                        <div class=\"barBg\"><div class=\"bar\">&nbsp;</div></div>\n                        <div class=\"num\">\n                            <span>100%</span>\n                            <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/progressBar_icon4.png?v=1708671099\" alt=\"\">\n                     