    "collapsible_content_AC88R9": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_hajVVq": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How assembled is the MF-30 Rear Drive Electric Trike when it arrives, and what will I need to do to finish the assembly?",
            "icon": "none",
            "row_content": "<p>The MF-30 Rear Drive electric trike comes 85% pre-assembled. Only simple components need to be installed, and these can be easily put in place.</p>",
            "page": ""
          }
        },
        "collapsible_row_UXtbED": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is the trike suitable for seniors or individuals with disabilities?",
            "icon": "none",
            "row_content": "<p>Of course! The Maxfoot electric trike comes with a saddle. It has a backrest. This ensures a comfortable riding experience.</p>",
            "page": ""
          }
        },
        "collapsible_row_P6gxpe": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Does the electric trike come with a battery and both front and rear baskets included?",
            "icon": "none",
            "row_content": "<p>The MF-30 Rear Drive electric trike comes with a battery, front basket and the rear basket.</p>",
            "page": ""
          }
        },
        "collapsible_row_Y6byHJ": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What kind of warranty is included with Maxfoot electric trike in the United States?",
            "icon": "none",
            "row_content": "<p>Maxfoot electric trikes come with a 1-year warranty. Learn more about the <a href=\"https://maxfoot.bike/policies/terms-of-service\" title=\"Maxfoot electric trike warranty\">Maxfoot Warranty</a>.</p>",
            "page": ""
          }
        }
      },
