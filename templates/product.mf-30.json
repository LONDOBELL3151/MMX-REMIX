      ],
      "settings": {
        "custom_liquid": "<style>\n    * {\n        margin: 0;\n        padding: 0;\n    }\n\n    html {\n        font-family: 'Arial';\n    }\n\n    .electricEngine {\n        position: relative;\n        max-width: 1920px;\n        width: 100%;\n        overflow: hidden;\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        flex-flow: row-reverse;\n        margin: 0 auto;\n    }\n\n    .electricEngine_L {\n        max-width: 610px;\n        width: 100%;\n        position: absolute;\n        left: 10%;\n        top: 10%;\n    }\n\n    .electricEngine_L_title {\n        font-size: 70px;\n        color: #151515;\n        font-weight: 600;\n    }\n\n    .electricEngine_L_word {\n        max-width: 500px;\n        width: 100%;\n        font-size: 18px;\n        color: #0e0e0e;\n        font-weight: 400;\n        padding-top: 40px;\n        line-height: 30px;\n    }\n\n    .electricEngine_L_tip {\n        display: flex;\n        align-items: center;\n        justify-content: flex-start;\n        padding-top: 80px;\n    }\n\n    .electricEngine_L_tip div:first-child {\n        margin-right: 55px;\n    }\n\n    .electricEngine_L_tip_box h6 {\n        font-size: 34px;\n        font-weight: 600;\n        margin-block-start: auto;\n        margin-block-end: auto;\n    }\n\n    .electricEngine_L_tip_box p {\n        font-size: 18px;\n        font-weight: 400;\n        margin-top: 20px;\n    }\n\n    .electricEngine_R_bg {\n        max-width: 1920px;\n        width: 100%;\n    }\n\n    .electricEngine_R_bgPhone {\n        max-width: 800px;\n        width: 100%;\n        display: none;\n    }\n\n    .electricEngine_R_bg img,\n    .electricEngine_R_bgPhone img {\n        display: block;\n        width: 100%;\n        height: 100%;\n    }\n\n    .electricEngine_L_title {\n        position: relative;\n    }\n\n    .underline_title {\n        position: absolute;\n        bottom: -10px;\n        left: 0px;\n        z-index: -1;\n    }\n</style>\n<style>\n    .electricEngine_R_bikeA img {\n        max-width: 700px;\n        width: 100%;\n        transition: all 1s;\n    }\n\n    .b,\n    .c,\n    .d,\n    .a {\n        position: absolute;\n        top: 11%;\n    }\n\n    .a {\n        right: 18%;\n        z-index: 4;\n    }\n\n    .b {\n        right: 17%;\n        z-index: 3;\n    }\n\n    .c {\n        right: 17%;\n        z-index: 2;\n    }\n\n    .d {\n        right: 17%;\n    }\n\n    .electricEngine_R_bikePhone {\n        display: none;\n    }\n\n    @media only screen and (max-width: 1750px) {\n        .electricEngine_R_bikeA {\n            zoom: .95;\n        }\n    }\n\n    @media only screen and (max-width: 1650px) {\n        .electricEngine_R_bikeA {\n            zoom: .90;\n        }\n    }\n\n    @media only screen and (max-width: 1550px) {\n        .electricEngine_R_bikeA {\n            zoom: .85;\n        }\n\n        .electricEngine_L_title {\n            font-size: 50px;\n        }\n\n        .electricEngine_L_word {\n            max-width: 400px;\n            font-size: 16px;\n            padding-top: 25px;\n            line-height: 25px;\n        }\n\n        .electricEngine_L_tip {\n            padding-top: 50px;\n        }\n\n        .electricEngine_L_tip_box h6 {\n            font-size: 23px;\n        }\n\n        .electricEngine_L_tip_box p {\n            font-size: 16px;\n            margin-top: 10px;\n        }\n\n    }\n\n    @media only screen and (max-width: 1450px) {\n        .electricEngine_R_bikeA {\n            zoom: .80;\n        }\n    }\n\n    @media only screen and (max-width: 1350px) {\n        .electricEngine_R_bikeA {\n            zoom: .75;\n        }\n\n        .electricEngine_L {\n            left: 7%;\n            zoom: .97;\n        }\n    }\n\n    @media only screen and (max-width: 1250px) {\n        .electricEngine_R_bikeA {\n            zoom: .70;\n        }\n\n        .electricEngine_L {\n            left: 5%;\n            zoom: .95;\n        }\n\n        .electricEngine_L_title {\n            font-size: 30px;\n        }\n\n        .electricEngine_L_tip {\n            padding-top: 35px;\n        }\n\n        .electricEngine_L_tip div:first-child {\n            margin-right: 30px;\n        }\n\n        .electricEngine_L_tip_box h6 {\n            font-size: 18px;\n        }\n\n        .electricEngine_L_tip_box p {\n            font-size: 14px;\n        }\n    }\n\n    @media only screen and (max-width: 1150px) {\n        .electricEngine_R_bikeA {\n            zoom: .65;\n        }\n\n        .electricEngine_L {\n            left: 3%;\n            zoom: .90;\n        }\n    }\n\n    @media only screen and (max-width: 1050px) {\n        .electricEngine_R_bikeA {\n            zoom: .60;\n        }\n\n        .electricEngine_L {\n            left: 3%;\n            zoom: .85;\n        }\n    }\n\n    @media only screen and (max-width: 950px) {\n        .electricEngine_R_bikeA {\n            zoom: .55;\n        }\n        .electricEngine_L {\n            zoom: .80;\n        }\n    }\n\n    @media only screen and (max-width: 850px) {\n        .electricEngine_R_bikeA {\n            zoom: .50;\n        }\n    }\n\n    @media only screen and (max-width: 800px) {\n        .electricEngine {\n            max-width: 800px;\n            display: block;\n        }\n\n        .electricEngine_L {\n            position: initial;\n            max-width: 100%;\n            margin: 35px auto;\n            padding: 0 10px;\n            box-sizing: border-box;\n            zoom: 1;\n        }\n\n        .electricEngine_L_word {\n            max-width: 100%;\n        }\n\n        .electricEngine_L_tip {\n            padding-top: 20px;\n        }\n\n        .a,\n        .b,\n        .c,\n        .d {\n            top: 12%;\n            right: auto;\n        }\n\n        .a {\n            left: 3%;\n        }\n\n        .b,\n        .c,\n        .d {\n            left: 5%;\n        }\n\n        .electricEngine_R_bikeA,\n        .electricEngine_R_bg {\n            display: none;\n        }\n\n        .electricEngine_R_bikePhone,\n        .electricEngine_R_bgPhone {\n            display: block;\n        }\n\n        .electricEngine_R_bikePhone>div {\n            position: absolute;\n            top: 0;\n        }\n\n        .electricEngine_R_bikePhone img {\n            max-width: 450px;\n            width: 100%;\n        }\n\n        .aPhone {\n            right: 19%;\n            z-index: 4;\n        }\n\n        .bPhone {\n            right: 17%;\n            z-index: 3;\n        }\n\n        .cPhone {\n            right: 17%;\n            z-index: 2;\n        }\n\n        .dPhone {\n            right: 17%;\n        }\n    }\n\n    @media only screen and (max-width: 750px) {\n        .electricEngine_R_bikePhone {\n            zoom: .90;\n        }\n    }\n\n    @media only screen and (max-width: 700px) {\n        .electricEngine_R_bikePhone {\n            zoom: .85;\n        }\n    }\n\n    @media only screen and (max-width: 650px) {\n        .electricEngine_R_bikePhone {\n            zoom: .80;\n        }\n    }\n\n    @media only screen and (max-width: 600px) {\n        .electricEngine_R_bikePhone {\n            zoom: .75;\n        }\n    }\n\n    @media only screen and (max-width: 550px) {\n        .electricEngine_R_bikePhone {\n            zoom: .70;\n        }\n\n        .electricEngine_L_title {\n            font-size: 20px;\n        }\n\n        .electricEngine_L_word {\n          \n            padding-top: 10px;\n            line-height: 20px;\n        }\n\n        .electricEngine_L_tip_box h6 {\n            font-size: 15px;\n        }\n\n        .electricEngine_L_tip_box p {\n            font-size: 12px;\n            margin-top: 5px;\n        }\n    }\n\n    @media only screen and (max-width: 500px) {\n        .electricEngine_R_bikePhone {\n            zoom: .65;\n        }\n    }\n\n    @media only screen and (max-width: 450px) {\n        .electricEngine_R_bikePhone {\n            zoom: .60;\n        }\n    }\n\n    @media only screen and (max-width: 400px) {\n        .electricEngine_R_bikePhone {\n            zoom: .55;\n        }\n    }\n\n    @media only screen and (max-width: 350px) {\n        .electricEngine_R_bikePhone {\n            zoom: .50;\n        }\n    }\n\n    @media only screen and (max-width: 330px) {\n        .electricEngine_R_bikePhone {\n            zoom: .45;\n        }\n    }\n</style>\n\n<div class=\"electricEngine\">\n    <div class=\"electricEngine_R_bg\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/wheel_j.jpg?v=1713943396\" alt=\"\">\n    </div>\n    <div class=\"electricEngine_R_bgPhone\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/phone_wheel_j.jpg?v=1713946926\" alt=\"\">\n    </div>\n    <div class=\"electricEngine_R_bikeA\">\n        <div class=\"a\"><img src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700MF.webp?v=1703732143\"\n                alt=\"\"></div>\n        <div class=\"b\"><img class=\"bb\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700_a1.gif?v=1682404760\" alt=\"\"></div>\n        <div class=\"c\"><img class=\"cc\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/700_b2.gif?v=1682578312\" alt=\"\"></div>\n        <div class=\"d\"><img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/700.png?v=1682146092\"\n                alt=\"\"></div>\n    </div>\n    <div class=\"electricEngine_R_bikePhone\">\n        <div class=\"aPhone\"><img\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500MF.webp?v=1703732177\" alt=\"\"></div>\n        <div class=\"bPhone\"><img class=\"bbPhone\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500_a1.gif?v=1682578976\" alt=\"\"></div>\n        <div class=\"cPhone\"><img class=\"ccPhone\"\n                src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/500_b1.gif?v=1682578976\" alt=\"\"></div>\n        <div class=\"dPhone\"><img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/500.png?v=1682146089\"\n                alt=\"\"></div>\n    </div>\n    <div class=\"electricEngine_L\">\n        <h3 class=\"electricEngine_L_title\">\n            MAXFOOT 750W<br> Rear Drive Motor\n        </h3>\n        <p class=\"electricEngine_L_word\">The MAXFOOT powerful motor provides the MF-30 with a rated power of 750W (peak power 1100W) and a powerful torque of 85N.m. \n            In the new version in 2024, the position of the MF-30's motor has been changed to the rear wheel position. \n            This means that the entire vehicle is driven by the two rear wheels, and the driving mode is changed from the original <b>\"pull\"</b> to <b>\"push\"</b>. When riding on some special terrain, the front wheel will no longer slip. \n            The MAXFOOT motor will work with the two rear wheels to easily push you forward. Free from terrain anxiety, your rides will be easier and more enjoyable.</p>\n    </div>\n</div>\n\n<script src=\"{{ 'gsap.js' | asset_url }}\"></script>\n<script src=\"{{ 'scrollTrigger.js' | asset_url }}\"></script>\n<script>\n    var timerImg, timeOneImg, timeTwoImg;\n    function gsapFun(num1, num2) {\n        gsap.registerPlugin(ScrollTrigger);\n        gsap.timeline({\n            scrollTrigger: {\n                trigger: \".electricEngine\",\n                start: \"top center\",\n                end: \"top 10px\",\n                scrub: true\n            } \n        })\n            .to('.electricEngine_R_bg', { x: 100, opacity: 0.05 }, 0)\n            .to('.a', { x: num1 }, 0)\n            .to('.b', { x: num2, }, 0)\n    }\n\n    function gsapFunPhone(num1, num2) {\n        gsap.registerPlugin(ScrollTrigger);\n        gsap.timeline({\n            scrollTrigger: {\n                trigger: \".electricEngine\",\n                start: \"top center\",\n                end: \"+=40%\",\n                scrub: true\n            }\n        })\n            .to('.electricEngine_R_bgPhone', { x: 50, opacity: 0.05 }, 0)\n            .to('.aPhone', { x: num1 }, 0)\n            .to('.bPhone', { x: num2, }, 0)\n    }\n\n\n    window.onload = function () {\n        gsapFun(-250, -20)\n        gsapFunPhone(-160, -20)\n    }\n\n    const iframeDom = document.querySelector('.electricEngine_R_bikeA')\n    const iframeDomPhone = document.querySelector('.electricEngine_R_bikePhone')\n    function aa(width, zoom, widthPhone, zoomPhone) {\n        if (window.innerWidth < width) {\n            iframeDom.style.zoom = window.innerWidth * zoom / width\n        } else {\n            iframeDom.style.zoom = zoom\n        }\n        if (window.innerWidth < widthPhone) {\n            iframeDomPhone.style.zoom = window.innerWidth * zoomPhone / widthPhone\n        } else {\n            iframeDomPhone.style.zoom = zoom\n        }\n    }\n    aa(1920, 1.02, 800, 1)\n    window.onresize = function () {\n        aa(1920, 1.02, 800, 1)\n    }\n</script>",
