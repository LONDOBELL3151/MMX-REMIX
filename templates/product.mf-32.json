{\n     font-size: 20px;\n }\n .module_colorBike_change span {\n     width: 30px;\n     height: 30px;\n }\n .module_colorBike_bg {\n     padding: 20px 10px;\n     box-sizing: border-box;\n     text-align: center;\n }\n}\n@media only screen and (max-width: 600px) {\n .module_colorBike_change {\n     flex-flow: column;\n }\n\n} \n </style>\n <div class=\"module_colorBike_bg\">\n     <div class=\"module_colorBike_imgBox\">\n         <img src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/B_76d6c657-2b49-45f8-a713-9a7c6410506c.png?v=1714898727\" alt=\"\">\n         <img src=\"https://cdn.shopifycdn.net/s/files/1/0081/3039/6242/files/G_663a3077-f864-4953-bf38-7a9377e81d65.png?v=1714898741\" alt=\"\">\n     </div>\n     <h5>2 Color For Your Choice</h5>\n     <div class=\"module_colorBike_change\">\n         <div>\n             <p>Picton Blue</p>\n             <span class=\"module_colorBike_change_one\"></span>\n         </div>\n         <input type=\"range\" oninput=\"this.parentNode.parentNode.style.setProperty('--pos', this.value / 100)\" >\n         <div>\n             <span class=\"module_colorBike_change_two\"></span>\n             <p>Pangea Green</p>\n         </div>\n     </div>\n </div>",
