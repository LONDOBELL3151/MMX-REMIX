        "custom_liquid": "<style>\n.module_battery_bg {\n    background-color: #121212;\n    padding: 20px 0;\n}\n.module_battery_box {\n    max-width: 1400px;\n    width: 100%;\n    margin: auto;\n    display: flex;\n    align-items: center;\n    justify-content: space-evenly;\n}\n.module_battery_word{\n    color: #fff;\n}\n.module_battery_word h3 {\n    font-size: 35px;\n    font-weight: 600;\n    color: #fff;\n    margin: 0;\n    line-height: initial;\n    padding: 0;\n}\n.module_battery_word h6 {\n    font-size: 23px;\n    font-weight: 600;\n    padding: 0;\n    line-height: initial;\n    padding-bottom: 7px;\n    color: #fff;\n    margin: 0;\n}\n.module_battery_word p {\n    font-size: 18px;\n    padding-bottom: 3px;\n    color: #fff;\n    line-height: initial;\n}\n.module_battery_img img {\n    width: 100%;\n    height: 100%;\n    display: block;\n    margin: auto;\n}\n.module_battery_progressBar {\n    margin-top: 35px;\n}\n.module_battery_progressBar .barBg {\n    background-color: #fff;\n    width: 60%;\n    border-radius: 100px;\n    line-height: 1;\n}\n.module_battery_progressBar .bar {\n    animation: striped-flow 3s linear infinite;\n    background-image: linear-gradient(45deg, rgba(0, 0, 0, .1) 25%, transparent 25%, transparent 50%, rgba(0, 0, 0, .1) 50%, rgba(0, 0, 0, .1) 75%, transparent 75%, transparent);\n    background-size: 1.25em 1.25em;\n    background-color: #009dff;\n    border-radius: 100px;\n    white-space: nowrap;\n    transition: width .6s ease;\n    width: 100%;\n    animation-duration: 30s;\n}\n@keyframes striped-flow {\n    0% {\n        background-position: -100%\n    }\n\n    to {\n        background-position: 100%\n    }\n}\n.module_battery_progressBar .barBg_a .bar {\n    width: 80%;\n}\n\n.module_battery_progressBar .barBg_b .bar{\n    background-color: #777777;\n    width: 60%;\n}\n.module_battery_progressBar .bar_box_b {\n    margin-top: 10px;\n}\n.module_battery_progressBar_titleIcone {\n    display: flex;\n}\n.module_battery_progressBar_titleIcone img{\n    display: block;\n    margin: 0;\n    width: 30px;\n    height: 30px;\n}\n.module_battery_progressBar .bar_box_barBg_d{\n    margin-top: 10px;\n}\n.module_battery_progressBar .barBg_c .bar{\n    width: 95%;\n}\n.module_battery_progressBar .barBg_d .bar{\n    background-color: #777777;\n    width: 40%;\n}\n@media only screen and (max-width: 1000px) {\n    .module_battery_box {\n        position: relative;\n    }\n    .module_battery_box {\n        display: block;\n        padding: 20px 10px;\n        box-sizing: border-box;\n        overflow: hidden;\n    }\n    .module_battery_img {\n        max-width: 150px;\n        width: 100%;\n        position: absolute;\n        right: 10%;\n        /* transform: rotate(32deg); */\n        bottom: 0;\n    }\n    .module_battery_progressBar .barBg {\n        width: 55%;\n    }\n    .module_battery_word {\n        position: relative;\n        z-index: 3;\n    }\n}\n@media only screen and (max-width: 800px) {\n    .module_battery_img {\n        max-width: 130px;\n    }\n}\n@media only screen and (max-width: 700px) {\n    .module_battery_word h3 {\n        font-size: 25px;\n    }\n    .module_battery_progressBar {\n        margin-top: 25px;\n    }\n    .module_battery_word h6 {\n        font-size: 20px;\n    }\n    .module_battery_word p {\n        font-size: 16px;\n    }\n    .module_battery_progressBar .barBg {\n        width: 50%;\n        line-height: 0.8;\n    }\n}\n@media only screen and (max-width: 600px) {\n    .module_battery_img {\n        max-width: 100px;\n        right: 13%;\n    }\n}\n@media only screen and (max-width: 400px) {\n    .module_battery_img {\n        max-width: 80px;\n        right: 13%;\n    }\n}\n    </style>\n    <div class=\"module_battery_bg\">\n        <div class=\"module_battery_box\">\n            <div class=\"module_battery_word\">\n                <h3>High-Quality & High-Capacity Battery</h3>\n                <h3>With Ul Certification</h3>\n                <div class=\"module_battery_progressBar\">\n                    <h6>Range Develop</h6>\n                    <div class=\"bar_box\">\n                        <p>Maxfoot 20Ah Battery</p>\n                        <div class=\"barBg barBg_a\"><div class=\"bar\">&nbsp;</div></div>\n                    </div>\n                    <div class=\"bar_box bar_box_b\">\n                        <p>Sliver Battery</p>\n                        <div class=\"barBg barBg_b\"><div class=\"bar\">&nbsp;</div></div>\n                    </div>\n                </div>\n                <div class=\"module_battery_progressBar\">\n                    <div class=\"module_battery_progressBar_titleIcone\">\n                        <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/icon_ul.png?v=1713770976\" alt=\"\">\n                        <h6>Quality Develop</h6>\n                    </div>\n                    <div class=\"bar_box\">\n                        <p>Maxfoot 20Ah Battery</p>\n                        <div class=\"barBg barBg_c\"><div class=\"bar\">&nbsp;</div></div>\n                    </div>\n                    <div class=\"bar_box bar_box_barBg_d\">\n                        <p>Sliver Battery</p>\n                        <div class=\"barBg barBg_d\"><div class=\"bar\">&nbsp;</div></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"module_battery_img\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0081/3039/6242/files/battery.png?v=1713770978\" alt=\"\">\n            </div>\n        </div>\n    </div>",
