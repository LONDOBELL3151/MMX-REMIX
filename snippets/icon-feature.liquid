{%- liquid
  assign name = icon | handleize
  assign size = size | default: 48
  assign stroke = color | default: 'currentColor'
-%}

{%- case name -%}
  {%- when 'compact' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 14h26M34 14v6M34 26v10M8 26h26v6H8z"/>
      <path d="M14 32v6M28 32v6"/>
      <circle cx="21" cy="20" r="3"/>
    </svg>
  {%- when 'storage' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="24" cy="12" rx="16" ry="5"/>
      <path d="M8 12v10c0 2.8 7.2 5 16 5s16-2.2 16-5V12"/>
      <path d="M8 22v10c0 2.8 7.2 5 16 5s16-2.2 16-5V22"/>
    </svg>
  {%- when 'money' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="24" cy="24" rx="18" ry="12"/>
      <path d="M28 19c-.8-1.6-2.4-2.5-4-2.5-2.2 0-4 1.4-4 3.3 0 1.8 1.6 2.6 3.6 3.1 2.4.6 4.4 1.3 4.4 3.6 0 2-1.8 3.5-4 3.5-1.8 0-3.4-1-4.2-2.7"/>
      <path d="M24 14v3M24 31v3"/>
    </svg>
  {%- when 'check' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="8" y="8" width="24" height="24" rx="3"/>
      <path d="M14 20l5 5 11-11"/>
      <path d="M32 28v8a4 4 0 0 1-4 4H14"/>
    </svg>
  {%- when 'eco' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M38 10c-10 0-18 6-18 16 0 6 3 10 7 12-2-4-2-9 0-13 3-7 11-12 18-12-3 0-6 0-9 1"/>
      <path d="M22 38c-2-4-2-9 0-13 3-7 11-12 18-12"/>
      <path d="M14 42l8-4"/>
    </svg>
  {%- when 'power' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="12" y="6" width="24" height="36" rx="3"/>
      <path d="M22 28l8-12h-5l5-8-10 14h5l-3 6z" fill="{{ stroke }}" stroke="none"/>
      <path d="M18 12h12"/>
    </svg>
  {%- else -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 48 48" fill="none" stroke="{{ stroke }}" stroke-width="2" aria-hidden="true">
      <circle cx="24" cy="24" r="18"/>
    </svg>
{%- endcase -%}
