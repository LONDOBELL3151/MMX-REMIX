{%- comment -%}
  Renders the product's `product_family` color swatches — a clickable
  row of COLOR CIRCLES (one per sibling product) so the user can
  switch between colors by jumping to another product page.

  Why this exists (context, 2026-07-07):
    - In main-product.liquid, when the product has a `product_family`
      metaobject with >1 members, the in-product variant picker is
      SKIPPED to avoid duplicate color UI.
    - This snippet takes over color selection: each circle links to a
      sibling product's PDP.

  Display:
    - Label: "Color: <current-short-name>"  (only the CURRENT color's
      name is shown as info; sibling swatches are unlabeled dots).
    - Below the label: a row of solid COLOR CIRCLES, one per family
      member, horizontally laid out and wrapping on narrow viewports.
      - The current product's circle shows the short color name below
        it AND is rendered as a non-interactive `<span>` with the
        `is-active` ring.
      - All other sibling circles are clickable `<a>` to the sibling
        product URL — only the circle (no label) renders for those.
    - Circle fill resolved per member in this order:
        1. product.metafields.custom.color_hex  (per-product override)
        2. keyword match on the color name (orange/gray/green/blue/…)
        3. neutral gray fallback (#cccccc)
    - The short name = last two words of the full color name when the
      full name has more than 2 words.

  Renders nothing when `product_family.members.size <= 1`, so the
  parent falls back to the in-product variant picker for single-color
  products.
{%- endcomment -%}

{%- liquid
  assign product_family = product.metafields.custom.product_family.value
  assign family_members = blank
  if product_family and product_family.members.value.size > 1
    assign family_members = product_family.members.value
  endif
-%}

{%- if family_members != blank -%}
  {%- liquid
    # short name = last two words of the color name
    assign color_short = product.title
    assign name_parts = product.title | split: ' '
    assign parts_size = name_parts | size
    if parts_size > 2
      assign drop_count = parts_size | minus: 2
      assign color_short = ''
      for part in name_parts
        if forloop.index0 >= drop_count
          assign color_short = color_short | append: part
          unless forloop.last
            assign color_short = color_short | append: ' '
          endunless
        endif
      endfor
    endif
  -%}
  <div class="pdp__option pdp__option--family" data-color-family>
    <label class="pdp__option-label">
      Color: <strong>{{ color_short }}</strong>
    </label>
    <div class="pdp__swatches pdp__swatches--family">
      {%- for member in family_members -%}
        {%- liquid
          assign member_product = member.product
          assign member_color_name = member_product.metafields.custom.color_name
          if member_color_name == blank
            assign member_color_name = member_product.title
          endif

          # member short name = last two words
          assign member_short = member_color_name
          assign m_parts = member_color_name | split: ' '
          assign m_parts_size = m_parts | size
          if m_parts_size > 2
            assign m_drop = m_parts_size | minus: 2
            assign member_short = ''
            for m_part in m_parts
              if forloop.index0 >= m_drop
                assign member_short = member_short | append: m_part
                unless forloop.last
                  assign member_short = member_short | append: ' '
                endunless
              endif
            endfor
          endif

          # member circle fill: metafield hex -> keyword match -> gray
          assign member_hex = member_product.metafields.custom.color_hex
          if member_hex == blank
            assign m_lower = member_color_name | downcase
            assign member_hex = '#cccccc'
            if m_lower contains 'orange'
              assign member_hex = '#e8632a'
            elsif m_lower contains 'gray' or m_lower contains 'grey' or m_lower contains 'silver'
              assign member_hex = '#6b6e72'
            elsif m_lower contains 'green'
              assign member_hex = '#3e7c4f'
            elsif m_lower contains 'blue'
              assign member_hex = '#2e4a7a'
            elsif m_lower contains 'red' or m_lower contains 'burgundy'
              assign member_hex = '#b32330'
            elsif m_lower contains 'black'
              assign member_hex = '#1a1a1a'
            elsif m_lower contains 'white'
              assign member_hex = '#f2f2f2'
            elsif m_lower contains 'yellow'
              assign member_hex = '#f4c430'
            elsif m_lower contains 'purple' or m_lower contains 'violet'
              assign member_hex = '#6a4c93'
            elsif m_lower contains 'pink'
              assign member_hex = '#e56399'
            elsif m_lower contains 'brown' or m_lower contains 'tan' or m_lower contains 'khaki'
              assign member_hex = '#8a6d3b'
            endif
          endif

          assign is_current = false
          if member_product.handle == product.handle
            assign is_current = true
          endif
        -%}
        {%- if is_current -%}
          <span class="swatch swatch--family swatch--current is-active"
                data-swatch="{{ member_product.handle }}"
                data-color-name="{{ member_color_name | escape }}"
                title="{{ member_color_name | escape }}"
                aria-current="page">
            <span class="swatch__color" style="background:{{ member_hex }}"></span>
            <span class="swatch__label">{{ member_short }}</span>
          </span>
        {%- else -%}
          <a class="swatch swatch--family"
             href="{{ member_product.url }}"
             data-swatch="{{ member_product.handle }}"
             data-color-name="{{ member_color_name | escape }}"
             title="{{ member_color_name | escape }}">
            <span class="swatch__color" style="background:{{ member_hex }}"></span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}