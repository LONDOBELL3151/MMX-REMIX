{%- liquid
  assign stars = rating | default: 5 | round
-%}
<span class="stars" aria-label="{{ stars }} out of 5 stars">
  {%- for i in (1..5) -%}
    {%- if i <= stars -%}
      {% render 'icon', icon: 'star', size: 14 %}
    {%- else -%}
      {% render 'icon', icon: 'star-outline', size: 14 %}
    {%- endif -%}
  {%- endfor -%}
</span>