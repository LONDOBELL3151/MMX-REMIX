{%- liquid
  assign b = block.settings
-%}
<article class="promo-card" {{ block.shopify_attributes }}>
  {%- if b.image != blank -%}
    <div class="promo-card__media">
      {{
        b.image
        | image_url: width: 800
        | image_tag:
          widths: '400, 600, 800, 1000',
          sizes: '(min-width: 990px) 33vw, (min-width: 560px) 50vw, 100vw',
          loading: 'lazy',
          class: 'promo-card__image',
          alt: b.image.alt | default: b.heading | escape
      }}
    </div>
  {%- endif -%}

  <div class="promo-card__body">
    {%- if b.heading != blank -%}
      <h3 class="promo-card__heading">{{ b.heading | escape }}</h3>
    {%- endif -%}

    {%- if b.body != blank -%}
      <p class="promo-card__text">{{ b.body | newline_to_br }}</p>
    {%- endif -%}

    {%- if b.button_text != blank and b.button_link != blank -%}
      <a href="{{ b.button_link }}" class="promo-card__cta">
        <span>{{ b.button_text | escape }}</span>
        <svg
          class="promo-card__cta-icon"
          viewBox="0 0 1024 1024"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M885.113 489.373L628.338 232.599c-12.496-12.497-32.758-12.497-45.254 0-12.497 12.497-12.497 32.758 0 45.255l203.3 203.3H158.025c-17.036 0-30.846 13.811-30.846 30.846 0 17.036 13.811 30.846 30.846 30.846h628.36L583.084 746.147c-12.497 12.496-12.497 32.758 0 45.255 6.248 6.248 14.438 9.372 22.627 9.372s16.379-3.124 22.627-9.372l256.775-256.775a31.999 31.999 0 0 0 0-45.254z" fill="currentColor"></path>
        </svg>
      </a>
    {%- endif -%}
  </div>
</article>
