{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}
<style>
 .color-selector-tip {
   display: none;
 }
  variant-color .color-selector:hover {
    position: relative;
  }
  variant-color .color-selector:hover .color-selector-tip {
        display: block;
    position: absolute;
    border: 1px solid #e4e7ed;
    border-radius: 4px;
    padding: 5px 10px;
    color: #606266;
    font-size: 14px;
    box-shadow: 0px 0px 12px rgba(0, 0, 0, .12);
    overflow-wrap: break-word;
    box-sizing: border-box;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    background: #fff;
  }
  .color-selector-tip span:first-child {
    text-wrap: nowrap;
  }
  span.el-popper__arrow {
     position: absolute;
    left: 0;
    width: 10px;
    height: 10px;
    right: 0;
    display: block;
    margin: auto;
    z-index: 1;
    top: -5px;
  }
  span.el-popper__arrow:before {
       position: absolute;
    width: 10px;
    height: 10px;
    z-index: -1;
    content: " ";
    transform: rotate(45deg);
    border-bottom-color: transparent !important;
    border-right-color: transparent !important;
    border-bottom-right-radius: 2px;
    border: 1px solid #e4e7ed;
    right: 0;
    background: #fff;
    box-sizing: border-box;
    left: 0;
    top: 0;
  }
</style>
{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if block.settings.picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      name="{{ option.name }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if option.selected_value == value %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
    >
    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
      {{ value -}}
      <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
    </label>
    {%- elsif block.settings.picker_type == 'color' -%}
        {% comment %} 色块 {% endcomment %}
        {% liquid
            assign swatch_file_extension = 'png'
            assign color_swatch_fallback = value | split: ' ' | last | handle
            assign img_name = value | replace: " ", "_" | append: '.' | append: swatch_file_extension
            assign image = images[img_name]
            %}
        
        <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" name="{{ option.name }}"
        value="{{ value | escape }}" form="{{ product_form_id }}" {% if option.selected_value == value %} checked
        {% endif %} {% if option_disabled %} class="disabled" {% endif %}>
        {%- if image != blank  -%}
            <div class="color-selector {% if option_disabled %} disabled{% endif %}">
                <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                    style="background-image: url({{ image | img_url:width:20 }}); background-color: {{ color_swatch_fallback }};"></label>
                <div class="color-selector-tip">
                  <span>{{ value | escape }}</span>
                  <span class="el-popper__arrow"></span>
                </div>
            </div>
        {%- else -%}
            <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                {{ value -}}
                <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
            </label>
        {%- endif -%}
  {%- elsif block.settings.picker_type == 'dropdown' -%}
    <option
      value="{{ value | escape }}"
      {% if option.selected_value == value %}
        selected="selected"
      {% endif %}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}
