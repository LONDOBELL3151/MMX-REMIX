.bicycle-swiperBanner {
    background: #16151a;
    padding: 70px 0;
    position: relative;
}
.bicycle-swiperBanner-box {
    position: relative;
	max-width: 1100px;
    width: 100%;
	margin: 0 auto
}
.bicycle-swiperBanner-box .swiper-slide {
    position: relative;
    max-width: 620px;
    width: 100%;
    height: auto;
    border-radius: 20px;
}
.bicycle-swiperBanner-box .swiper-slide-next::after,
.bicycle-swiperBanner-box  .swiper-slide-prev::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
}
.bicycle-swiperBanner img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
}
.bicycle-swiperBanner-box  .swiper-container,
.bicycle-swiperBanner-box {
    position: initial;
}
.bicycle-swiperBanner .swiper-button-next, 
.bicycle-swiperBanner .swiper-container-rtl .swiper-button-prev {
    right: 6%;
    background: url({{ 'prev.svg' | asset_url }}) no-repeat;
    background-size: 100% 100%;
    display: flex;
}
.bicycle-swiperBanner .swiper-button-next:after,
.bicycle-swiperBanner .swiper-rtl .swiper-button-prev:after,
.bicycle-swiperBanner .swiper-button-prev:after, .bicycle-swiperBanner .swiper-rtl .swiper-button-next:after {
    content:'';
}
.bicycle-swiperBanner .swiper-button-prev, 
.bicycle-swiperBanner .swiper-container-rtl .swiper-button-next {
    left: 6%;
    background: url({{ 'next.svg' | asset_url }}) no-repeat;
    background-size: 100% 100%;
    display: flex;
}
.bicycle-swiperBanner .swiper-button-next,
.bicycle-swiperBanner .swiper-button-prev {
    color: #ffffff;
}
.bicycle-swiperBanner-title {
    text-align: center;
    margin-bottom: 35px;
    color: #fff;
    font-size: 40px;
    font-weight: 600;
}
@media only screen and (max-width: 1200px) {
    .bicycle-swiperBanner-box {
        max-width: 800px;
    }
    .bicycle-swiperBanner-box .swiper-slide {
        max-width: 550px;
    }
}
@media only screen and (max-width: 900px) {
    .bicycle-swiperBanner-box {
        max-width: 600px;
    }
    .bicycle-swiperBanner-box .swiper-slide {
        max-width: 450px;
    }
}
@media only screen and (max-width: 750px) {
    .bicycle-swiperBanner-title {
        font-size: 27px;
    }
}
@media only screen and (max-width: 650px) {
    .bicycle-swiperBanner-box {
        max-width: 500px;
        padding: 0 20px;
        box-sizing: border-box;
    }
    .bicycle-swiperBanner-box .swiper-slide {
        max-width: 100%;
        width: calc(100vw - 40px);
        height: 400px;
    }
}